### Step 2: Implement Core Fallback Handler (120 lines)
**File**: `pkg/certs/fallback/fallback.go`

```go
package fallback

import (
    "context"
    "fmt"
    "github.com/cnoe-io/idpbuilder/pkg/certs"
    "github.com/cnoe-io/idpbuilder/pkg/registry"
)

// FallbackType categorizes the type of fallback being applied
type FallbackType string

const (
    FallbackTypeInsecure    FallbackType = "insecure"
    FallbackTypeRetry       FallbackType = "retry"
    FallbackTypeAlternateCA FallbackType = "alternate_ca"
    FallbackTypeUserPrompt  FallbackType = "user_prompt"
)

// SecurityLevel indicates the security impact of a fallback
type SecurityLevel string

const (
    SecurityLevelCritical SecurityLevel = "critical"
    SecurityLevelHigh     SecurityLevel = "high"
    SecurityLevelMedium   SecurityLevel = "medium"
    SecurityLevelLow      SecurityLevel = "low"
)

// FallbackStrategy defines a recovery strategy for certificate errors
type FallbackStrategy struct {
    Type            FallbackType
    RequiresFlag    bool
    SecurityImpact  SecurityLevel
    Recommendations []string
    WarningMessage  string
}

// FallbackHandler interface for handling certificate errors
type FallbackHandler interface {
    HandleCertError(err error) (*FallbackStrategy, error)
    ApplyInsecureMode(config *registry.BuildConfig) error
    LogSecurityDecision(decision string, reason string)
    GetRecommendations(err error) []string
    RequiresUserConfirmation() bool
}

// Handler implements FallbackHandler
type Handler struct {
    logger        SecurityLogger
    insecureMode  bool
    autoRecover   bool
    strictMode    bool
}

// NewHandler creates a new fallback handler
func NewHandler(opts ...Option) *Handler {
    h := &Handler{
        logger:       NewSecurityLogger(),
        insecureMode: false,
        autoRecover:  true,
        strictMode:   false,
    }

    for _, opt := range opts {
        opt(h)
    }

    return h
}

// HandleCertError analyzes the error and returns appropriate strategy
func (h *Handler) HandleCertError(err error) (*FallbackStrategy, error) {
    // Categorize the error
    category := categorizeCertError(err)

    switch category {
    case ErrCategoryExpired:
        return h.handleExpiredCert(err)
    case ErrCategorySelfSigned:
        return h.handleSelfSignedCert(err)
    case ErrCategoryHostnameMismatch:
        return h.handleHostnameMismatch(err)
    case ErrCategoryChainIncomplete:
        return h.handleIncompleteChain(err)
    default:
        return h.handleUnknownError(err)
    }
}

// Additional implementation details...
```

### Step 3: Implement Recommendations Engine (100 lines)
**File**: `pkg/certs/fallback/recommendations.go`

```go
package fallback

import (
    "fmt"
    "strings"
)

// ErrorCategory categorizes certificate errors
type ErrorCategory string

const (
    ErrCategoryExpired          ErrorCategory = "expired"
    ErrCategorySelfSigned       ErrorCategory = "self_signed"
    ErrCategoryHostnameMismatch ErrorCategory = "hostname_mismatch"
    ErrCategoryChainIncomplete  ErrorCategory = "chain_incomplete"
    ErrCategoryUnknown          ErrorCategory = "unknown"
)

// RecommendationEngine generates actionable recommendations
type RecommendationEngine struct {
    verbose bool
}

// NewRecommendationEngine creates a new recommendation engine
func NewRecommendationEngine(verbose bool) *RecommendationEngine {
    return &RecommendationEngine{verbose: verbose}
}

// GetRecommendations returns recommendations for the given error
func (r *RecommendationEngine) GetRecommendations(err error, category ErrorCategory) []string {
    var recommendations []string

    switch category {
    case ErrCategoryExpired:
        recommendations = r.getExpiredCertRecommendations()
    case ErrCategorySelfSigned:
        recommendations = r.getSelfSignedRecommendations()
    case ErrCategoryHostnameMismatch:
        recommendations = r.getHostnameMismatchRecommendations()
    case ErrCategoryChainIncomplete:
        recommendations = r.getIncompleteChainRecommendations()
    default:
        recommendations = r.getGenericRecommendations()
    }

    if r.verbose {
        recommendations = append(recommendations, r.getVerboseDetails(err)...)
    }

    return recommendations
}

// Category-specific recommendation generators
func (r *RecommendationEngine) getExpiredCertRecommendations() []string {
    return []string{
        "Certificate has expired. Contact your administrator to renew it.",
        "As a temporary workaround, you can use --insecure flag (NOT recommended for production)",
        "To update the certificate: kubectl exec -it <gitea-pod> -- /bin/sh -c 'cd /data/gitea && ./generate-cert.sh'",
    }
}

// Additional recommendation methods...
```

### Step 4: Implement Security Logger (80 lines)
**File**: `pkg/certs/fallback/security_log.go`

```go
package fallback

import (
    "fmt"
    "log/slog"
    "os"
    "time"
)

// SecurityLogger logs security-relevant decisions
type SecurityLogger interface {
    LogDecision(decision string, reason string, impact SecurityLevel)
    LogBypass(certError error, method string)
    GetAuditTrail() []SecurityEvent
}

// SecurityEvent represents a security-relevant event
type SecurityEvent struct {
    Timestamp time.Time
    Decision  string
    Reason    string
    Impact    SecurityLevel
    User      string
    Method    string
}

// Logger implements SecurityLogger
type Logger struct {
    events []SecurityEvent
    output *slog.Logger
    file   *os.File
}

// NewSecurityLogger creates a new security logger
func NewSecurityLogger() *Logger {
    logFile, _ := os.OpenFile("/tmp/idpbuilder-security.log",
        os.O_CREATE|os.O_WRONLY|os.O_APPEND, 0600)

    return &Logger{
        events: make([]SecurityEvent, 0),
        output: slog.New(slog.NewTextHandler(logFile, nil)),
        file:   logFile,
    }
}

// LogDecision logs a security decision
func (l *Logger) LogDecision(decision string, reason string, impact SecurityLevel) {
    event := SecurityEvent{
        Timestamp: time.Now(),
        Decision:  decision,
        Reason:    reason,
        Impact:    impact,
        User:      os.Getenv("USER"),
    }

    l.events = append(l.events, event)

    l.output.Warn("SECURITY DECISION",
        "decision", decision,
        "reason", reason,
        "impact", impact,
        "user", event.User,
    )
}

// Additional logging methods...
```

### Step 5: Implement Insecure Mode Handler (100 lines)
**File**: `pkg/certs/fallback/insecure.go`

```go
package fallback

import (
    "crypto/tls"
    "fmt"
    "github.com/cnoe-io/idpbuilder/pkg/registry"
    "net/http"
)

// InsecureConfig handles --insecure flag operations
type InsecureConfig struct {
    Enabled         bool
    RequireConfirm  bool
    LogAllRequests  bool
    WarningShown    bool
}

// InsecureModeHandler manages insecure mode operations
type InsecureModeHandler struct {
    config *InsecureConfig
    logger SecurityLogger
}

// NewInsecureModeHandler creates a new insecure mode handler
func NewInsecureModeHandler(logger SecurityLogger) *InsecureModeHandler {
    return &InsecureModeHandler{
        config: &InsecureConfig{
            Enabled:        false,
            RequireConfirm: true,
            LogAllRequests: true,
            WarningShown:   false,
        },
        logger: logger,
    }
}

// Enable enables insecure mode with appropriate warnings
func (h *InsecureModeHandler) Enable(force bool) error {
    if !force && h.config.RequireConfirm {
        if !h.promptUserConfirmation() {
            return fmt.Errorf("insecure mode cancelled by user")
        }
    }

    h.showSecurityWarning()
    h.config.Enabled = true
    h.logger.LogDecision("INSECURE_MODE_ENABLED",
        "User enabled insecure mode",
        SecurityLevelCritical)

    return nil
}

// ApplyToTransport applies insecure settings to HTTP transport
func (h *InsecureModeHandler) ApplyToTransport(transport *http.Transport) error {
    if !h.config.Enabled {
        return fmt.Errorf("insecure mode not enabled")
    }

    transport.TLSClientConfig = &tls.Config{
        InsecureSkipVerify: true,
    }

    h.logger.LogDecision("TLS_VERIFICATION_DISABLED",
        "Applied insecure TLS config to transport",
        SecurityLevelCritical)

    return nil
}

// showSecurityWarning displays security warning to user
func (h *InsecureModeHandler) showSecurityWarning() {
    if h.config.WarningShown {
        return
    }

    fmt.Println("⚠️  WARNING: INSECURE MODE ENABLED ⚠️")
    fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    fmt.Println("• TLS certificate verification is DISABLED")
    fmt.Println("• Your connection is vulnerable to MITM attacks")
    fmt.Println("• This mode should NEVER be used in production")
    fmt.Println("• All operations are being logged for audit")
    fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

    h.config.WarningShown = true
}

// Additional insecure mode methods...
```

