{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://software-factory.dev/schemas/orchestrator-state-v2-hybrid.schema.json",
  "title": "Software Factory 2.0/3.0 Hybrid Orchestrator State",
  "description": "Schema for orchestrator-state-v3.json - HYBRID format with SF 2.0 flat structure and SF 3.0 state_machine object. This schema supports transition period state files.",
  "type": "object",
  "required": [
    "current_state",
    "previous_state",
    "current_phase",
    "current_wave"
  ],
  "properties": {
    "current_state": {
      "type": "string",
      "description": "Current state in state machine (SF 2.0 flat field)"
    },
    "previous_state": {
      "type": ["string", "null"],
      "description": "Previous state before transition (SF 2.0 flat field)"
    },
    "transition_time": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp of last transition"
    },
    "current_phase": {
      "type": "integer",
      "description": "Current phase number (SF 2.0 flat field)",
      "minimum": 1
    },
    "current_wave": {
      "type": "integer",
      "description": "Current wave number within phase (SF 2.0 flat field)",
      "minimum": 1
    },
    "phases_planned": {
      "type": ["integer", "null"],
      "description": "Total number of phases planned",
      "minimum": 1
    },
    "total_phases": {
      "type": ["integer", "null"],
      "description": "Alias for phases_planned",
      "minimum": 1
    },
    "waves_per_phase": {
      "type": ["object", "null"],
      "description": "Map of phase_number to waves_count",
      "additionalProperties": {
        "type": "integer",
        "minimum": 1
      }
    },
    "total_waves_in_phase": {
      "type": "integer",
      "description": "CRITICAL: Total waves in current phase - REQUIRED for state machine guard evaluation",
      "minimum": 1
    },
    "waves_completed": {
      "type": "integer",
      "description": "CRITICAL: Number of waves completed in current phase - MUST BE INTEGER not array!",
      "minimum": 0
    },
    "phases_completed": {
      "type": ["array", "null"],
      "description": "List of completed phase numbers",
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "all_phases_complete": {
      "type": ["boolean", "null"],
      "description": "Whether all phases are complete"
    },
    "efforts_completed": {
      "type": ["array", "null"],
      "description": "List of completed effort IDs",
      "items": {
        "type": "string"
      }
    },
    "efforts_in_progress": {
      "type": ["array", "null"],
      "description": "List of in-progress effort IDs",
      "items": {
        "type": "string"
      }
    },
    "efforts_pending": {
      "type": ["array", "null"],
      "description": "List of pending effort IDs",
      "items": {
        "type": "string"
      }
    },
    "project_info": {
      "type": ["object", "null"],
      "description": "Project metadata",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": ["string", "null"]
        },
        "target_repo": {
          "type": ["string", "null"],
          "format": "uri"
        }
      }
    },
    "project_name": {
      "type": ["string", "null"],
      "description": "Project name (flat field)"
    },
    "project_description": {
      "type": ["string", "null"],
      "description": "Project description (flat field)"
    },
    "project_type": {
      "type": ["string", "null"],
      "description": "Type of project"
    },
    "codebase_type": {
      "type": ["string", "null"],
      "description": "Codebase type (greenfield/brownfield)"
    },
    "target_repo_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Target repository URL"
    },
    "prd_pre_exists": {
      "type": ["boolean", "null"],
      "description": "Whether PRD existed before factory start"
    },
    "non_interactive_mode": {
      "type": ["boolean", "null"],
      "description": "Whether running in non-interactive mode"
    },
    "state_machine": {
      "type": ["object", "null"],
      "description": "SF 3.0 state machine object (nested)",
      "properties": {
        "name": {
          "type": ["string", "null"]
        },
        "version": {
          "type": ["string", "null"]
        },
        "file": {
          "type": ["string", "null"]
        },
        "current_state": {
          "type": ["string", "null"],
          "description": "Current state (duplicates root current_state)"
        },
        "previous_state": {
          "type": ["string", "null"],
          "description": "Previous state (duplicates root previous_state)"
        },
        "loop_detection": {
          "type": ["object", "null"],
          "description": "SF 3.0 loop detection counters",
          "properties": {
            "last_two_states": {
              "type": ["array", "null"],
              "items": {
                "type": "string"
              },
              "maxItems": 2
            },
            "ping_pong_count": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "same_state_count": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "error_recovery_entries": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "last_progress_timestamp": {
              "type": ["string", "null"],
              "format": "date-time"
            },
            "validate_infrastructure_loops": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "iteration_count": {
              "type": ["integer", "null"],
              "minimum": 0
            }
          }
        },
        "state_history": {
          "type": ["array", "null"],
          "description": "History of state transitions",
          "items": {
            "type": "object",
            "properties": {
              "from_state": {
                "type": "string"
              },
              "to_state": {
                "type": "string"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "validated_by": {
                "type": ["string", "null"]
              },
              "reason": {
                "type": ["string", "null"]
              }
            }
          }
        }
      }
    },
    "state_history": {
      "type": ["array", "null"],
      "description": "Flat state history (SF 2.0 style)",
      "items": {
        "type": "object"
      }
    },
    "state_transitions": {
      "type": ["array", "null"],
      "description": "State transition log",
      "items": {
        "type": "object"
      }
    },
    "last_action": {
      "type": ["string", "null"],
      "description": "Description of last action taken"
    },
    "last_state_transition": {
      "type": ["string", "null"],
      "description": "Timestamp or description of last transition"
    },
    "transition_reason": {
      "type": ["string", "null"],
      "description": "Reason for last transition"
    },
    "next_actions": {
      "type": ["array", "null"],
      "description": "List of next planned actions",
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Generic timestamp"
    },
    "last_updated": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Update timestamp"
    },
    "active_agents": {
      "type": ["array", "null"],
      "description": "List of active agents",
      "items": {
        "type": "object"
      }
    },
    "sw_engineer_parallelization": {
      "type": ["object", "null"],
      "description": "SW Engineer parallelization settings"
    },
    "code_reviewer_parallelization": {
      "type": ["object", "null"],
      "description": "Code Reviewer parallelization settings"
    },
    "spawn_timing": {
      "type": ["object", "null"],
      "description": "Agent spawn timing data"
    },
    "monitoring_data": {
      "type": ["object", "null"],
      "description": "Monitoring and metrics data"
    },
    "line_count_tracking": {
      "type": ["object", "null"],
      "description": "Line count tracking data"
    },
    "blocked_items": {
      "type": ["array", "null"],
      "description": "List of blocked items",
      "items": {
        "type": "object"
      }
    },
    "phase_assessments": {
      "type": ["object", "array", "null"],
      "description": "Phase assessment results (can be object map or array)"
    },
    "phase1_integration": {
      "type": ["object", "null"],
      "description": "Phase 1 integration data"
    },
    "project_integration": {
      "type": ["object", "null"],
      "description": "Project integration data"
    },
    "wave_integration_progress": {
      "type": ["object", "null"],
      "description": "Wave integration progress tracking"
    },
    "wave_integration_review": {
      "type": ["object", "null"],
      "description": "Wave integration review results"
    },
    "wave_2_fix_progress": {
      "type": ["object", "null"],
      "description": "Wave 2 fix progress tracking"
    },
    "final_artifact": {
      "type": ["object", "null"],
      "description": "Final artifact information"
    }
  },
  "additionalProperties": true,

  "anyOf": [
    {
      "description": "Either total_waves_in_phase OR waves_per_phase must be present",
      "required": ["total_waves_in_phase"]
    },
    {
      "required": ["waves_per_phase"]
    }
  ],

  "if": {
    "properties": {
      "waves_per_phase": {
        "type": "object"
      },
      "current_phase": {
        "type": "integer"
      }
    },
    "required": ["waves_per_phase", "current_phase"]
  },
  "then": {
    "description": "If waves_per_phase exists, derive total_waves_in_phase validation",
    "properties": {
      "waves_completed": {
        "type": "integer",
        "description": "Must be integer when using waves_per_phase"
      }
    }
  }
}
