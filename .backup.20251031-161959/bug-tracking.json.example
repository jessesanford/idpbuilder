      "bug_id": "BUG-004-INCORRECT-STATUS-CODE",
      "discovered_by": "code-reviewer",
      "discovered_at": "2025-10-07T16:30:00Z",
      "severity": "LOW",
      "status": "VERIFIED",
      "title": "Incorrect HTTP status code for rate limit exceeded",
      "description": "Rate limiter returns HTTP 500 (Internal Server Error) when rate limit is exceeded, but should return HTTP 429 (Too Many Requests) per RFC 6585. This makes it difficult for clients to distinguish between rate limiting and actual server errors.",
      "location": {
        "file_path": "pkg/ratelimit/middleware.go",
        "line_number": 52,
        "function_name": "RateLimitMiddleware",
        "code_snippet": "http.Error(w, \"Rate limit exceeded\", http.StatusInternalServerError)"
      },
