      "cascade_id": null,
      "related_bugs": [],
      "fix_history": [
        {
          "attempt_number": 1,
          "started_at": "2025-10-08T11:20:00Z",
          "completed_at": "2025-10-08T12:10:00Z",
          "attempt_status": "FIXED",
          "fixed_by": "sw-engineer",
          "fix_branch": "phase2-wave3-rate-limiting-fix-bug003",
          "commit_hash": "a7f3e2d1c9b8a5f4e3d2c1b0a9f8e7d6c5b4a3f2",
          "notes": "Added background cleanup goroutine with configurable TTL for inactive buckets"
        }
      ],
