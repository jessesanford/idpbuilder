    {
      "bug_id": "BUG-005-CACHE-KEY-COLLISION",
      "discovered_by": "architect",
      "discovered_at": "2025-10-08T10:45:00Z",
      "severity": "HIGH",
      "status": "VERIFIED",
      "title": "Cache key collision between different resource types",
      "description": "Cache key generation uses only resource ID without type prefix, causing collisions when different resource types (users, posts, comments) share the same numeric ID. This leads to incorrect data being served from cache.",
      "location": {
        "file_path": "pkg/cache/keys.go",
        "line_number": 23,
        "function_name": "GenerateKey",
        "code_snippet": "return fmt.Sprintf(\"%d\", resourceID) // Missing type prefix"
      },
      "affected_effort": "phase2-wave3-caching-layer",
      "affected_container": "wave_2_3",
      "fix_branch": "phase2-wave3-caching-layer-fix-bug005",
