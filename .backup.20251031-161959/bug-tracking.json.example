      "bug_id": "BUG-001-NULL-POINTER-WEBHOOK",
      "discovered_by": "code-reviewer",
      "discovered_at": "2025-10-08T13:25:00Z",
      "severity": "HIGH",
      "status": "IN_PROGRESS",
      "title": "Null pointer dereference in webhook handler",
      "description": "The webhook handler does not properly validate the payload before accessing nested fields. When a webhook payload is missing the 'metadata' field, the code attempts to access payload.metadata.id without a nil check, causing a runtime panic.",
      "location": {
        "file_path": "pkg/webhooks/handler.go",
        "line_number": 145,
        "function_name": "HandleWebhookEvent",
        "code_snippet": "eventID := payload.metadata.id // PANIC: metadata can be nil"
      },
      "affected_effort": "phase2-wave3-webhook-system",
      "affected_container": "wave_2_3",
