    {
      "bug_id": "BUG-002-RACE-CONDITION-CACHE",
      "discovered_by": "code-reviewer",
      "discovered_at": "2025-10-08T13:28:00Z",
      "severity": "CRITICAL",
      "status": "OPEN",
      "title": "Race condition in cache invalidation logic",
      "description": "The cache layer has concurrent map writes without proper synchronization. Multiple goroutines can simultaneously invalidate cache entries, leading to map corruption and potential data races. This occurs when rate limiting triggers cache invalidation while background cleanup is running.",
      "location": {
        "file_path": "pkg/cache/store.go",
        "line_number": 89,
        "function_name": "InvalidateKey",
        "code_snippet": "delete(c.entries, key) // RACE: concurrent map writes"
      },
      "affected_effort": "phase2-wave3-caching-layer",
      "affected_container": "wave_2_3",
      "fix_branch": null,
      "fixed_by": null,
      "fixed_at": null,
      "verified_by": null,
