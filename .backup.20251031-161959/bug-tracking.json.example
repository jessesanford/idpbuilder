    {
      "bug_id": "BUG-003-MEMORY-LEAK-RATE-LIMIT",
      "discovered_by": "code-reviewer",
      "discovered_at": "2025-10-08T11:15:00Z",
      "severity": "MEDIUM",
      "status": "FIXED",
      "title": "Memory leak in rate limiter token bucket cleanup",
      "description": "Rate limiter maintains a map of token buckets per client but never removes entries for inactive clients. Over time, this causes unbounded memory growth as the map accumulates entries for all clients that have ever made a request.",
      "location": {
        "file_path": "pkg/ratelimit/limiter.go",
        "line_number": 67,
        "function_name": "GetBucket",
        "code_snippet": "l.buckets[clientID] = newBucket() // Never cleaned up"
      },
      "affected_effort": "phase2-wave3-rate-limiting",
      "affected_container": "wave_2_3",
      "fix_branch": "phase2-wave3-rate-limiting-fix-bug003",
      "fixed_by": "sw-engineer",
      "fixed_at": "2025-10-08T12:10:00Z",
      "verified_by": "code-reviewer",
      "verified_at": "2025-10-08T12:45:00Z",
      "is_cross_container_bug": false,
