# Feature flags for R307 compliance - Independent mergeability
# These flags ensure the split can be merged independently without breaking existing functionality

# Enable core builder functionality from split-001 (dependency)
ENABLE_CORE_BUILDER=true

# Enable certificate management from split-002 (dependency) 
ENABLE_CERT_MANAGEMENT=true

# Enable CLI tools functionality for split-003
ENABLE_CLI_TOOLS=true
