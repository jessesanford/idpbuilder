{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://software-factory.dev/schemas/bug-tracking.schema.json",
  "title": "Software Factory 3.0 Bug Tracking State",
  "description": "Schema for bug-tracking.json - tracks all bugs discovered, fixed, and verified throughout the project lifecycle",
  "type": "object",
  "required": [
    "bugs"
  ],
  "properties": {
    "bugs": {
      "type": "array",
      "description": "Complete registry of all bugs discovered during code reviews with full lifecycle tracking",
      "items": {
        "type": [
          "object",
          "null"
        ],
        "required": [
          "bug_id",
          "discovered_by",
          "discovered_at",
          "severity",
          "status",
          "title",
          "description",
          "location",
          "affected_effort"
        ],
        "properties": {
          "bug_id": {
            "type": "string",
            "description": "Unique identifier for this bug",
            "pattern": "^BUG-[0-9]{3}-[A-Z_-]+$",
            "examples": [
              "BUG-001-DUPLICATE-PUSHCMD",
              "BUG-023-NULL-POINTER",
              "BUG-005-CACHE-KEY-COLLISION"
            ]
          },
          "discovered_by": {
            "type": "string",
            "description": "Agent that discovered this bug",
            "enum": [
              "code-reviewer",
              "architect",
              "sw-engineer",
              "orchestrator"
            ]
          },
          "discovered_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when bug was discovered"
          },
          "severity": {
            "type": "string",
            "description": "Severity level of the bug",
            "enum": [
              "CRITICAL",
              "HIGH",
              "MEDIUM",
              "LOW"
            ]
          },
          "status": {
            "type": "string",
            "description": "Current status of the bug in its lifecycle",
            "enum": [
              "OPEN",
              "IN_PROGRESS",
              "FIXED",
              "VERIFIED",
              "WONT_FIX"
            ]
          },
          "title": {
            "type": "string",
            "description": "Brief description of the bug",
            "minLength": 5,
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the bug, including reproduction steps and expected vs actual behavior"
          },
          "location": {
            "type": "object",
            "description": "Location information for where the bug exists",
            "required": [
              "file_path"
            ],
            "properties": {
              "file_path": {
                "type": "string",
                "description": "Path to the file containing the bug"
              },
              "line_number": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "Line number where bug occurs",
                "minimum": 1
              },
              "function_name": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Function or method where bug exists"
              },
              "code_snippet": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Relevant code snippet showing the bug"
              }
            }
          },
          "affected_effort": {
            "type": "string",
            "description": "Effort branch where this bug was discovered",
            "examples": [
              "phase1-wave1-core-types",
              "phase2-wave3-api-implementation"
            ]
          },
          "affected_container": {
            "type": [
              "string",
              "null"
            ],
            "description": "Integration container (wave/phase/project) where bug impacts integration",
            "examples": [
              "wave_1_1",
              "phase_2",
              "project"
            ]
          },
          "fix_branch": {
            "type": [
              "string",
              "null"
            ],
            "description": "Branch where fix is being implemented (optional, only when IN_PROGRESS or later)"
          },
          "fixed_by": {
            "type": [
              "string",
              "null"
            ],
            "description": "Agent that fixed the bug (optional, only when FIXED or VERIFIED)",
            "enum": [
              "sw-engineer",
              "architect",
              null
            ]
          },
          "fixed_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "ISO 8601 timestamp when bug was fixed (optional, only when FIXED or VERIFIED)"
          },
          "verified_by": {
            "type": [
              "string",
              "null"
            ],
            "description": "Agent that verified the fix (optional, only when VERIFIED)",
            "enum": [
              "code-reviewer",
              "architect",
              null
            ]
          },
          "verified_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "ISO 8601 timestamp when fix was verified (optional, only when VERIFIED)"
          },
          "is_cross_container_bug": {
            "type": [
              "boolean",
              "null"
            ],
            "description": "Whether this bug affects multiple integration containers (waves/phases)",
            "default": false
          },
          "triggers_fix_cascade": {
            "type": [
              "boolean",
              "null"
            ],
            "description": "Whether this bug triggered a fix cascade sub-state machine",
            "default": false
          },
          "cascade_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "Identifier of the fix cascade that was triggered by this bug (optional, only when triggers_fix_cascade=true)"
          },
          "related_bugs": {
            "type": [
              "array",
              "null"
            ],
            "description": "IDs of related bugs (duplicates, dependencies, etc.)",
            "items": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "fix_history": {
            "type": [
              "array",
              "null"
            ],
            "description": "History of fix attempts for this bug",
            "items": {
              "type": [
                "object",
                "null"
              ],
              "required": [
                "attempt_number",
                "started_at",
                "attempt_status"
              ],
              "properties": {
                "attempt_number": {
                  "type": "integer",
                  "description": "Sequential number of this fix attempt",
                  "minimum": 1
                },
                "started_at": {
                  "type": "string",
                  "format": "date-time",
                  "description": "When this fix attempt started"
                },
                "completed_at": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date-time",
                  "description": "When this fix attempt completed"
                },
                "attempt_status": {
                  "type": "string",
                  "description": "Status of this fix attempt",
                  "enum": [
                    "IN_PROGRESS",
                    "FIXED",
                    "FAILED",
                    "ABANDONED"
                  ]
                },
                "fixed_by": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Agent that worked on this fix attempt"
                },
                "fix_branch": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Branch used for this fix attempt"
                },
                "commit_hash": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Git commit hash of the fix"
                },
                "notes": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Additional notes about this fix attempt"
                }
              }
            }
          },
          "reintegration_status": {
            "type": [
              "object",
              "null"
            ],
            "description": "Status of re-integration after bug fix",
            "properties": {
              "reintegrated": {
                "type": [
                  "boolean",
                  "null"
                ],
                "description": "Whether fix has been re-integrated into the container",
                "default": false
              },
              "reintegration_iteration": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "Which iteration of the container this fix was re-integrated in",
                "minimum": 1
              },
              "reintegrated_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time",
                "description": "When fix was re-integrated"
              }
            }
          },
          "impact_analysis": {
            "type": [
              "object",
              "null"
            ],
            "description": "Analysis of bug impact on the project",
            "properties": {
              "blocks_integration": {
                "type": [
                  "boolean",
                  "null"
                ],
                "description": "Whether this bug blocks integration from completing",
                "default": false
              },
              "affected_efforts": {
                "type": [
                  "array",
                  "null"
                ],
                "description": "List of effort IDs affected by this bug",
                "items": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "estimated_fix_time": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Estimated time to fix this bug (human-readable)",
                "examples": [
                  "2 hours",
                  "1 day",
                  "30 minutes"
                ]
              }
            }
          },
          "metadata": {
            "type": [
              "object",
              "null"
            ],
            "description": "Additional metadata about the bug",
            "properties": {
              "tags": {
                "type": [
                  "array",
                  "null"
                ],
                "description": "Tags categorizing the bug",
                "items": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "examples": [
                  [
                    "performance",
                    "memory-leak"
                  ],
                  [
                    "security",
                    "authentication"
                  ]
                ]
              },
              "priority": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "Priority ranking (1=highest, higher numbers=lower priority)",
                "minimum": 1
              },
              "regression": {
                "type": [
                  "boolean",
                  "null"
                ],
                "description": "Whether this is a regression from previously working code",
                "default": false
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": [
        "object",
        "null"
      ],
      "description": "Aggregate metadata and statistics about bug tracking",
      "properties": {
        "total_bugs": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Total count of bugs in the registry",
          "minimum": 0,
          "default": 0
        },
        "open_bugs": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Count of bugs with status OPEN",
          "minimum": 0,
          "default": 0
        },
        "in_progress_bugs": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Count of bugs with status IN_PROGRESS",
          "minimum": 0,
          "default": 0
        },
        "fixed_bugs": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Count of bugs with status FIXED",
          "minimum": 0,
          "default": 0
        },
        "verified_bugs": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Count of bugs with status VERIFIED",
          "minimum": 0,
          "default": 0
        },
        "critical_bugs": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Count of bugs with severity CRITICAL",
          "minimum": 0,
          "default": 0
        },
        "high_bugs": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Count of bugs with severity HIGH",
          "minimum": 0,
          "default": 0
        },
        "last_updated": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "ISO 8601 timestamp when this file was last updated"
        },
        "last_updated_by": {
          "type": [
            "string",
            "null"
          ],
          "description": "Agent that last updated this file",
          "default": "state-manager"
        }
      }
    },
    "statistics": {
      "type": [
        "object",
        "null"
      ],
      "description": "Statistical analysis of bug tracking and resolution",
      "properties": {
        "discovery_rates": {
          "type": [
            "object",
            "null"
          ],
          "description": "Bug discovery rate statistics",
          "properties": {
            "bugs_per_iteration": {
              "type": [
                "array",
                "null"
              ],
              "description": "Average bugs discovered per iteration at each integration level",
              "items": {
                "type": [
                  "object",
                  "null"
                ],
                "properties": {
                  "container_id": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Integration container ID"
                  },
                  "iteration": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "Iteration number"
                  },
                  "bugs_found": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "Bugs found in this iteration"
                  }
                }
              }
            },
            "bugs_per_effort": {
              "type": [
                "number",
                "null"
              ],
              "description": "Average bugs discovered per effort",
              "minimum": 0
            }
          }
        },
        "resolution_times": {
          "type": [
            "object",
            "null"
          ],
          "description": "Bug resolution time statistics",
          "properties": {
            "average_fix_time_hours": {
              "type": [
                "number",
                "null"
              ],
              "description": "Average time to fix a bug (in hours)",
              "minimum": 0
            },
            "average_verification_time_hours": {
              "type": [
                "number",
                "null"
              ],
              "description": "Average time to verify a fix (in hours)",
              "minimum": 0
            },
            "total_time_to_resolution_hours": {
              "type": [
                "number",
                "null"
              ],
              "description": "Average total time from discovery to verification (in hours)",
              "minimum": 0
            }
          }
        },
        "bug_density": {
          "type": [
            "object",
            "null"
          ],
          "description": "Bug density metrics across the project",
          "properties": {
            "bugs_per_1000_lines": {
              "type": [
                "number",
                "null"
              ],
              "description": "Average bugs per 1000 lines of code",
              "minimum": 0
            },
            "bugs_by_severity_percentage": {
              "type": [
                "object",
                "null"
              ],
              "description": "Percentage breakdown by severity",
              "properties": {
                "critical": {
                  "type": [
                    "number",
                    "null"
                  ],
                  "minimum": 0,
                  "maximum": 100
                },
                "high": {
                  "type": [
                    "number",
                    "null"
                  ],
                  "minimum": 0,
                  "maximum": 100
                },
                "medium": {
                  "type": [
                    "number",
                    "null"
                  ],
                  "minimum": 0,
                  "maximum": 100
                },
                "low": {
                  "type": [
                    "number",
                    "null"
                  ],
                  "minimum": 0,
                  "maximum": 100
                }
              }
            }
          }
        },
        "convergence_metrics": {
          "type": [
            "object",
            "null"
          ],
          "description": "Metrics showing convergence toward zero bugs in integration iterations",
          "properties": {
            "is_converging": {
              "type": [
                "boolean",
                "null"
              ],
              "description": "Whether bug counts are decreasing across iterations",
              "default": false
            },
            "bug_reduction_rate": {
              "type": [
                "number",
                "null"
              ],
              "description": "Average percentage reduction in bugs per iteration",
              "minimum": -100,
              "maximum": 100
            },
            "iterations_to_convergence_estimate": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Estimated iterations remaining until zero bugs",
              "minimum": 0
            }
          }
        }
      }
    },
    "cross_container_tracking": {
      "type": [
        "object",
        "null"
      ],
      "description": "Tracking of bugs that affect multiple integration containers",
      "properties": {
        "cross_container_bugs": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of bug IDs that are cross-container bugs",
          "items": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "cascade_triggered_bugs": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of bug IDs that triggered fix cascades",
          "items": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "active_cascades": {
          "type": [
            "array",
            "null"
          ],
          "description": "Currently active fix cascades",
          "items": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "cascade_id": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Unique identifier for this cascade"
              },
              "trigger_bug_id": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Bug ID that triggered this cascade"
              },
              "affected_containers": {
                "type": [
                  "array",
                  "null"
                ],
                "description": "List of container IDs affected by this cascade",
                "items": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "status": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  "IN_PROGRESS",
                  "COMPLETED",
                  "FAILED",
                  null
                ]
              }
            }
          }
        }
      }
    }
  }
}
