{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://software-factory.dev/schemas/integration-containers.schema.json",
  "title": "Software Factory 3.0 Integration Containers State",
  "description": "Schema for integration-containers.json - tracks active integration iteration containers (wave, phase, project) with integrate-fix-reintegrate loops",
  "type": "object",
  "required": [
    "active_integrations"
  ],
  "properties": {
    "active_integrations": {
      "type": "array",
      "description": "Array of active integration container objects tracking integrate-fix-reintegrate loops at wave/phase/project levels",
      "items": {
        "type": [
          "object",
          "null"
        ],
        "required": [
          "container_id",
          "container_type",
          "container_name",
          "status",
          "current_iteration",
          "max_iterations",
          "created_at",
          "integration_branch",
          "efforts_to_integrate",
          "efforts_integrated",
          "iteration_history",
          "convergence_metrics"
        ],
        "properties": {
          "container_id": {
            "type": "string",
            "description": "Unique identifier for this integration container",
            "examples": [
              "wave_1_1",
              "wave_2_3",
              "phase_1",
              "phase_2",
              "project"
            ]
          },
          "container_type": {
            "type": "string",
            "description": "Type of integration container - determines scope of integration",
            "enum": [
              "WAVE",
              "PHASE",
              "PROJECT"
            ]
          },
          "container_name": {
            "type": "string",
            "description": "Human-readable name for this container",
            "examples": [
              "Phase 1 Wave 1",
              "Phase 2 Integration",
              "Project Final Integration"
            ]
          },
          "status": {
            "type": "string",
            "description": "Current status of the integration container in its lifecycle",
            "enum": [
              "INTEGRATING",
              "REVIEWING",
              "FIXING",
              "REINTEGRATING",
              "CONVERGED",
              "FAILED"
            ]
          },
          "current_iteration": {
            "type": "integer",
            "description": "Current iteration number in the integrate-fix-reintegrate loop",
            "minimum": 1,
            "default": 1
          },
          "max_iterations": {
            "type": "integer",
            "description": "Maximum iterations allowed before escalation to manual intervention",
            "minimum": 1,
            "default": 10
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when this container was created"
          },
          "integration_branch": {
            "type": "string",
            "description": "Git branch name used for integration work in this container",
            "examples": [
              "phase1-wave1-integration",
              "phase2-integration",
              "main-integration"
            ]
          },
          "efforts_to_integrate": {
            "type": "array",
            "description": "Array of effort branch names that need to be integrated in this container",
            "items": {
              "type": [
                "string",
                "null"
              ]
            },
            "examples": [
              [
                "phase1-wave1-core-types",
                "phase1-wave1-api-handlers",
                "phase1-wave1-database"
              ]
            ]
          },
          "efforts_integrated": {
            "type": "array",
            "description": "Array of effort branch names that have been successfully integrated",
            "items": {
              "type": [
                "string",
                "null"
              ]
            },
            "default": []
          },
          "bugs_discovered": {
            "type": [
              "array",
              "null"
            ],
            "description": "Array of bug IDs discovered during integration in this container",
            "items": {
              "type": [
                "string",
                "null"
              ]
            },
            "default": []
          },
          "bugs_fixed": {
            "type": [
              "array",
              "null"
            ],
            "description": "Array of bug IDs that have been fixed and reintegrated in this container",
            "items": {
              "type": [
                "string",
                "null"
              ]
            },
            "default": []
          },
          "iteration_history": {
            "type": "array",
            "description": "History of all iterations in this container, tracking each integrate-fix-reintegrate cycle",
            "items": {
              "type": [
                "object",
                "null"
              ],
              "required": [
                "iteration_number",
                "started_at",
                "bugs_found",
                "integration_successful"
              ],
              "properties": {
                "iteration_number": {
                  "type": "integer",
                  "description": "Sequential iteration number (1, 2, 3, etc.)",
                  "minimum": 1
                },
                "started_at": {
                  "type": "string",
                  "format": "date-time",
                  "description": "ISO 8601 timestamp when this iteration started"
                },
                "completed_at": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date-time",
                  "description": "ISO 8601 timestamp when this iteration completed (null if still in progress)"
                },
                "bugs_found": {
                  "type": "integer",
                  "description": "Number of bugs discovered in this iteration",
                  "minimum": 0
                },
                "bugs_fixed": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "description": "Number of bugs fixed in this iteration",
                  "minimum": 0,
                  "default": 0
                },
                "integration_successful": {
                  "type": "boolean",
                  "description": "Whether the integration merge succeeded technically (even if bugs found in review)"
                },
                "review_completed": {
                  "type": [
                    "boolean",
                    "null"
                  ],
                  "description": "Whether code review was completed for this iteration",
                  "default": false
                },
                "outcome": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Outcome of this iteration",
                  "enum": [
                    "CLEAN",
                    "ISSUES_FOUND",
                    "IN_PROGRESS",
                    "FAILED",
                    "ABORTED",
                    null
                  ]
                },
                "bugs_discovered_ids": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "description": "Bug IDs discovered in this specific iteration",
                  "items": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "default": []
                },
                "bugs_fixed_ids": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "description": "Bug IDs fixed in this specific iteration",
                  "items": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "default": []
                },
                "notes": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Human-readable notes about this iteration (what happened, why, decisions made)"
                }
              }
            }
          },
          "convergence_metrics": {
            "type": "object",
            "description": "Metrics tracking convergence toward zero bugs and completion readiness",
            "required": [
              "total_bugs_discovered",
              "total_bugs_fixed",
              "bugs_remaining",
              "convergence_confidence"
            ],
            "properties": {
              "total_bugs_discovered": {
                "type": "integer",
                "description": "Total count of bugs discovered across all iterations in this container",
                "minimum": 0,
                "default": 0
              },
              "total_bugs_fixed": {
                "type": "integer",
                "description": "Total count of bugs fixed across all iterations in this container",
                "minimum": 0,
                "default": 0
              },
              "bugs_remaining": {
                "type": "integer",
                "description": "Current count of open bugs blocking convergence",
                "minimum": 0,
                "default": 0
              },
              "bug_discovery_rate": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "Average bugs discovered per iteration (calculated trend)",
                "minimum": 0
              },
              "bug_fix_rate": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "Average bugs fixed per iteration (calculated trend)",
                "minimum": 0
              },
              "estimated_iterations_remaining": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "Calculated estimate of iterations remaining until convergence",
                "minimum": 0
              },
              "convergence_confidence": {
                "type": "string",
                "description": "Confidence level in achieving convergence within max_iterations",
                "enum": [
                  "HIGH",
                  "MEDIUM",
                  "LOW",
                  "NONE"
                ]
              },
              "bugs_trend": {
                "type": [
                  "array",
                  "null"
                ],
                "description": "Array showing bug count trajectory across iterations (helps visualize convergence)",
                "items": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "examples": [
                  [
                    5,
                    2,
                    0
                  ],
                  [
                    8,
                    6,
                    4,
                    2
                  ]
                ]
              }
            }
          },
          "last_review_timestamp": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "ISO 8601 timestamp of the most recent code review in this container"
          },
          "last_integration_timestamp": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "ISO 8601 timestamp of the most recent integration attempt"
          },
          "is_converging": {
            "type": [
              "boolean",
              "null"
            ],
            "description": "Boolean indicating if bug count is decreasing (true = converging toward completion)",
            "default": false
          },
          "escalation_required": {
            "type": [
              "boolean",
              "null"
            ],
            "description": "Boolean indicating if manual intervention is needed (max iterations reached or non-convergence detected)",
            "default": false
          },
          "escalation_reason": {
            "type": [
              "string",
              "null"
            ],
            "description": "Human-readable reason why escalation was required (only set when escalation_required=true)",
            "examples": [
              "Max iterations reached without convergence",
              "Bug count increasing instead of decreasing",
              "Critical bug cannot be fixed automatically"
            ]
          },
          "architect_review_completed": {
            "type": [
              "boolean",
              "null"
            ],
            "description": "Whether architect has reviewed and approved this integration (required for completion)",
            "default": false
          },
          "architect_review_timestamp": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "ISO 8601 timestamp when architect review was completed"
          },
          "completion_criteria_met": {
            "type": [
              "boolean",
              "null"
            ],
            "description": "Whether all completion criteria are satisfied (zero bugs, architect approval, tests passing)",
            "default": false
          },
          "metadata": {
            "type": [
              "object",
              "null"
            ],
            "description": "Additional metadata about this integration container",
            "properties": {
              "phase_number": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "Phase number this container belongs to (for WAVE and PHASE containers)",
                "minimum": 1
              },
              "wave_number": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "Wave number this container belongs to (for WAVE containers only)",
                "minimum": 1
              },
              "parent_container_id": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Container ID of parent integration (e.g., WAVE container's parent is PHASE container)"
              },
              "child_containers": {
                "type": [
                  "array",
                  "null"
                ],
                "description": "Array of child container IDs (e.g., PHASE container lists its WAVE containers)",
                "items": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "total_efforts_count": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "Total number of efforts to integrate in this container",
                "minimum": 0
              },
              "total_integration_time_hours": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "Total time spent on integration across all iterations (in hours)",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": [
        "object",
        "null"
      ],
      "description": "Aggregate metadata and statistics about all integration containers",
      "properties": {
        "total_containers": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Total count of integration containers (active and completed)",
          "minimum": 0,
          "default": 0
        },
        "active_containers": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Count of containers currently in progress (not CONVERGED or FAILED)",
          "minimum": 0,
          "default": 0
        },
        "converged_containers": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Count of containers that have successfully converged",
          "minimum": 0,
          "default": 0
        },
        "failed_containers": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Count of containers that failed to converge",
          "minimum": 0,
          "default": 0
        },
        "total_iterations_across_all_containers": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Sum of all iterations across all containers",
          "minimum": 0,
          "default": 0
        },
        "average_iterations_to_convergence": {
          "type": [
            "number",
            "null"
          ],
          "description": "Average number of iterations needed to achieve convergence",
          "minimum": 0
        },
        "last_updated": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "ISO 8601 timestamp when this file was last updated"
        },
        "last_updated_by": {
          "type": [
            "string",
            "null"
          ],
          "description": "Agent that last updated this file",
          "default": "state-manager"
        }
      }
    },
    "convergence_statistics": {
      "type": [
        "object",
        "null"
      ],
      "description": "Statistical analysis of convergence patterns across all containers",
      "properties": {
        "overall_convergence_rate": {
          "type": [
            "number",
            "null"
          ],
          "description": "Overall percentage of containers that successfully converged",
          "minimum": 0,
          "maximum": 100
        },
        "average_bugs_per_iteration": {
          "type": [
            "number",
            "null"
          ],
          "description": "Average bugs discovered per iteration across all containers",
          "minimum": 0
        },
        "average_fix_velocity": {
          "type": [
            "number",
            "null"
          ],
          "description": "Average bugs fixed per iteration across all containers",
          "minimum": 0
        },
        "containers_by_type": {
          "type": [
            "object",
            "null"
          ],
          "description": "Breakdown of container statistics by type",
          "properties": {
            "wave_containers": {
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "total": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "active": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "converged": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "failed": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                }
              }
            },
            "phase_containers": {
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "total": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "active": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "converged": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "failed": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                }
              }
            },
            "project_containers": {
              "type": [
                "object",
                "null"
              ],
              "properties": {
                "total": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "active": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "converged": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "failed": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    },
    "completed_integrations": {
      "type": [
        "array",
        "null"
      ],
      "description": "Archive of completed integration containers (moved from active_integrations when CONVERGED or FAILED)",
      "items": {
        "type": [
          "object",
          "null"
        ],
        "description": "Same schema as active_integrations items, but for completed containers",
        "properties": {
          "container_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "container_type": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "WAVE",
              "PHASE",
              "PROJECT",
              null
            ]
          },
          "final_status": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "CONVERGED",
              "FAILED",
              null
            ]
          },
          "completed_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "When this container reached final state"
          },
          "total_iterations": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "total_bugs_discovered": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "total_bugs_fixed": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          }
        }
      }
    }
  }
}
