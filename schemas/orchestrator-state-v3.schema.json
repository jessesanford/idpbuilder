{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://software-factory.dev/schemas/orchestrator-state-v3.schema.json",
  "title": "Software Factory 3.0 Orchestrator State",
  "description": "Schema for orchestrator-state-v3.json - tracks state machine progression and project iteration containers",
  "type": "object",
  "required": [
    "state_machine",
    "project_progression",
    "references"
  ],
  "properties": {
    "state_machine": {
      "type": "object",
      "description": "State machine progression tracking - current state, transition history, and validation status",
      "required": [
        "current_state",
        "previous_state",
        "state_history",
        "last_transition_timestamp"
      ],
      "properties": {
        "current_state": {
          "type": "string",
          "description": "Current state in the Software Factory 3.0 state machine",
          "examples": [
            "REVIEW_WAVE_INTEGRATION",
            "SETUP_PHASE_INFRASTRUCTURE",
            "START_PROJECT_ITERATION"
          ]
        },
        "previous_state": {
          "type": "string",
          "description": "Previous state before current transition",
          "examples": [
            "INTEGRATE_WAVE_EFFORTS",
            "COMPLETE_WAVE"
          ]
        },
        "state_history": {
          "type": "array",
          "description": "Ordered history of state transitions with timestamps and reasons",
          "items": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "from_state",
              "to_state",
              "timestamp",
              "validated_by"
            ],
            "properties": {
              "from_state": {
                "type": "string",
                "description": "State transitioned from"
              },
              "to_state": {
                "type": "string",
                "description": "State transitioned to"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "ISO 8601 timestamp of transition"
              },
              "validated_by": {
                "type": "string",
                "description": "State Manager agent that validated this transition (MUST be 'state-manager' for SF 3.0 compliance)",
                "enum": ["state-manager"],
                "default": "state-manager"
              },
              "reason": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Human-readable reason for transition"
              },
              "orchestrator_proposal": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "State that orchestrator proposed during SHUTDOWN_CONSULTATION (added by State Manager when orchestrator makes proposal)"
              },
              "proposal_accepted": {
                "type": [
                  "boolean",
                  "null"
                ],
                "description": "Whether State Manager accepted orchestrator's proposal (true = accepted, false = rejected/overridden). Required when orchestrator_proposal is present."
              },
              "proposal_rejected_reason": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Explanation why State Manager rejected/overrode orchestrator's proposal (e.g., 'Cannot return to INIT - must continue mandatory sequence project_initialization'). Required when proposal_accepted is false."
              },
              "mandatory_sequence": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Name of mandatory sequence this transition belongs to (e.g., 'project_initialization')"
              },
              "sequence_position": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Position in mandatory sequence (e.g., '6/9' means step 6 of 9)"
              },
              "guards_evaluated": {
                "type": [
                  "object",
                  "null"
                ],
                "description": "Guard conditions that were evaluated for this transition"
              }
            },
            "if": {
              "properties": {
                "orchestrator_proposal": {
                  "type": "string"
                }
              },
              "required": ["orchestrator_proposal"]
            },
            "then": {
              "required": ["proposal_accepted"]
            },
            "else": {},
            "if": {
              "properties": {
                "proposal_accepted": {
                  "const": false
                }
              },
              "required": ["proposal_accepted"]
            },
            "then": {
              "required": ["proposal_rejected_reason"]
            },
            "else": {}
          }
        },
        "last_transition_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of most recent state transition"
        },
        "transition_validated": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "Whether current state transition was validated by State Manager",
          "default": true
        },
        "status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "ACTIVE",
            "PAUSED",
            "ERROR",
            null
          ],
          "description": "Status of state machine execution (PAUSED when sub-state machine active)",
          "default": "ACTIVE"
        },
        "sub_state_machine": {
          "type": [
            "object",
            "null"
          ],
          "description": "Sub-state machine status (e.g., fix cascade) when active",
          "properties": {
            "active": {
              "type": [
                "boolean",
                "null"
              ],
              "description": "Whether a sub-state machine is currently active"
            },
            "type": {
              "type": [
                "string",
                "null"
              ],
              "description": "Type of sub-state machine",
              "examples": [
                "fix-cascade"
              ]
            },
            "state_file": {
              "type": [
                "string",
                "null"
              ],
              "description": "Path to sub-state machine state file",
              "examples": [
                "fix-cascade-state.json"
              ]
            },
            "return_state": {
              "type": [
                "string",
                "null"
              ],
              "description": "State to return to when sub-state machine completes"
            }
          }
        },
        "loop_detection": {
          "type": "object",
          "description": "Loop detection counters for preventing infinite state transition cycles (R530)",
          "required": [
            "last_two_states",
            "ping_pong_count",
            "same_state_count",
            "error_recovery_entries"
          ],
          "properties": {
            "last_two_states": {
              "type": "array",
              "description": "Ring buffer of last 2 states for ping-pong detection (A->B->A->B pattern)",
              "items": {
                "type": "string"
              },
              "maxItems": 2,
              "default": []
            },
            "ping_pong_count": {
              "type": "integer",
              "description": "Counter for 2-state ping-pong loops (A->B->A->B). Threshold: 5 repetitions = ERROR_RECOVERY",
              "minimum": 0,
              "default": 0
            },
            "same_state_count": {
              "type": "integer",
              "description": "Counter for stuck-in-same-state loops (A->A->A). Threshold: 3 repetitions = ERROR_RECOVERY",
              "minimum": 0,
              "default": 0
            },
            "error_recovery_entries": {
              "type": "integer",
              "description": "Count of ERROR_RECOVERY state entries from different states. Threshold: 3 entries = ESCALATE to ERROR_RECOVERY",
              "minimum": 0,
              "default": 0
            },
            "last_progress_timestamp": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time",
              "description": "ISO 8601 timestamp of last genuine progress detection (resets all counters)"
            }
          }
        }
      }
    },
    "project_progression": {
      "type": "object",
      "description": "Project progression tracking through iteration containers (project/phase/wave hierarchy)",
      "required": [
        "current_project",
        "current_phase",
        "current_wave"
      ],
      "properties": {
        "current_project": {
          "type": "object",
          "description": "Current project container state",
          "required": [
            "project_id",
            "name",
            "iteration"
          ],
          "properties": {
            "project_id": {
              "type": "string",
              "description": "Unique identifier for this project"
            },
            "name": {
              "type": "string",
              "description": "Human-readable project name"
            },
            "iteration": {
              "type": "integer",
              "description": "Current iteration number for project-level integration",
              "minimum": 0,
              "default": 0
            },
            "max_iterations": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Maximum iterations allowed before escalation",
              "minimum": 1,
              "default": 10
            },
            "status": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "IN_PROGRESS",
                "COMPLETED",
                "ERROR",
                null
              ],
              "default": "IN_PROGRESS"
            }
          }
        },
        "current_phase": {
          "type": "object",
          "description": "Current phase container state",
          "required": [
            "phase_number",
            "name",
            "iteration",
            "total_waves_in_phase",
            "waves_completed"
          ],
          "properties": {
            "phase_number": {
              "type": "integer",
              "description": "Phase number (1, 2, 3, etc.)",
              "minimum": 1
            },
            "name": {
              "type": "string",
              "description": "Phase name or description"
            },
            "iteration": {
              "type": "integer",
              "description": "Current iteration number for phase-level integration",
              "minimum": 0,
              "default": 0
            },
            "max_iterations": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Maximum iterations allowed before escalation",
              "minimum": 1,
              "default": 10
            },
            "status": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "PLANNING",
                "IN_PROGRESS",
                "COMPLETED",
                "ERROR",
                null
              ],
              "default": "IN_PROGRESS"
            },
            "total_waves_in_phase": {
              "type": "integer",
              "description": "Total number of waves planned for this phase - CRITICAL for state machine guard evaluation at COMPLETE_WAVE to determine if more waves exist or if all waves are complete",
              "minimum": 1
            },
            "waves_completed": {
              "type": "integer",
              "description": "Number of waves completed in this phase - used with total_waves_in_phase for guard evaluation",
              "minimum": 0,
              "default": 0
            }
          }
        },
        "current_wave": {
          "type": "object",
          "description": "Current wave container state",
          "required": [
            "wave_number",
            "name",
            "iteration"
          ],
          "properties": {
            "wave_number": {
              "type": "integer",
              "description": "Wave number within current phase (1, 2, 3, etc.)",
              "minimum": 1
            },
            "name": {
              "type": "string",
              "description": "Wave name or description"
            },
            "iteration": {
              "type": "integer",
              "description": "Current iteration number for wave-level integration",
              "minimum": 0,
              "default": 0
            },
            "max_iterations": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Maximum iterations allowed before escalation",
              "minimum": 1,
              "default": 10
            },
            "status": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "PLANNING",
                "IN_PROGRESS",
                "COMPLETED",
                "ERROR",
                null
              ],
              "default": "IN_PROGRESS"
            },
            "efforts_completed": {
              "type": [
                "array",
                "null"
              ],
              "description": "List of completed effort identifiers in this wave",
              "items": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "iteration_tracking": {
          "type": [
            "object",
            "null"
          ],
          "description": "Metadata about iteration containers and convergence",
          "properties": {
            "active_container_level": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "wave",
                "phase",
                "project",
                "none",
                null
              ],
              "description": "Which integration level is currently active"
            },
            "active_container_id": {
              "type": [
                "string",
                "null"
              ],
              "description": "Identifier of the active integration container (matches entry in integration-containers.json)"
            }
          }
        }
      }
    },
    "references": {
      "type": "object",
      "description": "References to other state files in SF 3.0 separated state architecture",
      "required": [
        "bug_tracking_file",
        "integration_containers_file"
      ],
      "properties": {
        "bug_tracking_file": {
          "type": "string",
          "description": "Path to bug tracking state file",
          "default": "bug-tracking.json"
        },
        "integration_containers_file": {
          "type": "string",
          "description": "Path to integration containers state file",
          "default": "integration-containers.json"
        },
        "fix_cascade_state_file": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to fix cascade state file (only exists when cascade is active)",
          "default": "fix-cascade-state.json"
        },
        "state_machine_definition": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to state machine JSON definition file",
          "default": "state-machines/software-factory-3.0-state-machine.json"
        },
        "schema_version": {
          "type": [
            "string",
            "null"
          ],
          "description": "Version of this schema",
          "default": "3.0.0"
        }
      }
    },
    "metadata": {
      "type": [
        "object",
        "null"
      ],
      "description": "Additional metadata about the orchestrator state file",
      "properties": {
        "version": {
          "type": [
            "string",
            "null"
          ],
          "description": "Software Factory version",
          "default": "3.0.0"
        },
        "created_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "ISO 8601 timestamp when state file was created"
        },
        "last_updated": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "ISO 8601 timestamp when state file was last updated"
        },
        "last_updated_by": {
          "type": [
            "string",
            "null"
          ],
          "description": "Agent that last updated this state file",
          "default": "state-manager"
        }
      }
    },
    "planning_artifacts": {
      "type": [
        "object",
        "null"
      ],
      "description": "Tracks locations of planning artifacts for instant discovery without filesystem searching",
      "properties": {
        "master_architecture_file": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to master architecture document relative to project root - STANDARDIZED LOCATION",
          "pattern": "^planning/PROJECT-ARCHITECTURE\\.md$",
          "default": "planning/PROJECT-ARCHITECTURE.md"
        },
        "master_architecture_status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "NOT_CREATED",
            "IN_PROGRESS",
            "COMPLETE",
            null
          ],
          "description": "Status of master architecture creation",
          "default": "NOT_CREATED"
        },
        "master_architecture_created_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "ISO 8601 timestamp when master architecture was completed"
        },
        "master_architecture_created_by": {
          "type": [
            "string",
            "null"
          ],
          "description": "Agent that created the master architecture",
          "default": "architect"
        }
      }
    },
    "planning_files": {
      "type": [
        "object",
        "null"
      ],
      "description": "Tracking of all planning document locations per R550 - enables instant discovery without filesystem searching",
      "properties": {
        "project": {
          "type": [
            "object",
            "null"
          ],
          "description": "Project-level planning files",
          "properties": {
            "implementation_plan": {
              "type": [
                "string",
                "null"
              ],
              "description": "Path to project implementation plan (e.g., planning/project/PROJECT-IMPLEMENTATION-PLAN.md)"
            },
            "architecture_plan": {
              "type": [
                "string",
                "null"
              ],
              "description": "Path to project architecture plan (e.g., planning/project/PROJECT-ARCHITECTURE-PLAN.md)"
            },
            "test_plan": {
              "type": [
                "string",
                "null"
              ],
              "description": "Path to project test plan (e.g., planning/project/PROJECT-TEST-PLAN.md)"
            }
          }
        },
        "phases": {
          "type": [
            "object",
            "null"
          ],
          "description": "Phase-level planning files keyed by phase identifier (e.g., phase1, phase2)",
          "patternProperties": {
            "^phase[0-9]+$": {
              "type": "object",
              "description": "Planning files for a specific phase",
              "properties": {
                "architecture_plan": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Path to phase architecture plan (e.g., planning/phase1/PHASE-ARCHITECTURE-PLAN.md)"
                },
                "test_plan": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Path to phase test plan (e.g., planning/phase1/PHASE-TEST-PLAN.md)"
                },
                "waves": {
                  "type": [
                    "object",
                    "null"
                  ],
                  "description": "Wave-level planning files keyed by wave identifier (e.g., wave1, wave2)",
                  "patternProperties": {
                    "^wave[0-9]+$": {
                      "type": "object",
                      "description": "Planning files for a specific wave",
                      "properties": {
                        "implementation_plan": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Path to wave implementation plan (e.g., planning/phase1/wave1/WAVE-IMPLEMENTATION-PLAN.md)"
                        },
                        "test_plan": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "description": "Path to wave test plan (e.g., planning/phase1/wave1/WAVE-TEST-PLAN.md)"
                        },
                        "efforts": {
                          "type": [
                            "object",
                            "null"
                          ],
                          "description": "Effort-level planning files keyed by effort identifier",
                          "additionalProperties": {
                            "type": "object",
                            "description": "Planning files for a specific effort",
                            "properties": {
                              "implementation_plan": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "description": "Path to effort implementation plan (e.g., planning/phase1/wave1/effort-1.1.1-gitea-client.md)"
                              },
                              "split_plan": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "description": "Path to effort split plan if effort was split (e.g., planning/phase1/wave1/effort-1.1.1-gitea-client-SPLIT-PLAN.md)"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "active_agents": {
      "type": [
        "array",
        "null"
      ],
      "description": "List of currently active agent instances",
      "items": {
        "type": [
          "object",
          "null"
        ],
        "required": [
          "agent_type",
          "agent_id",
          "state"
        ],
        "properties": {
          "agent_type": {
            "type": "string",
            "description": "Type of agent",
            "enum": [
              "orchestrator",
              "state-manager",
              "sw-engineer",
              "code-reviewer",
              "architect"
            ]
          },
          "agent_id": {
            "type": "string",
            "description": "Unique identifier for this agent instance"
          },
          "state": {
            "type": "string",
            "description": "Current state of this agent"
          },
          "spawned_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "When this agent was spawned"
          },
          "workspace": {
            "type": [
              "string",
              "null"
            ],
            "description": "Workspace path for this agent"
          }
        }
      }
    },
    "phases": {
      "type": [
        "array",
        "null"
      ],
      "description": "SF 3.0 canonical phase tracking - replaces legacy phaseN_* accessor patterns. Contains standardized phase metadata for direct access via jq '.phases[] | select(.phase_number == N)'",
      "items": {
        "type": "object",
        "required": [
          "phase_number",
          "phase_name",
          "implementation_plan_path",
          "architecture_plan_path",
          "status"
        ],
        "properties": {
          "phase_number": {
            "type": "integer",
            "description": "Numeric phase identifier (1, 2, 3, etc.)",
            "minimum": 1
          },
          "phase_name": {
            "type": "string",
            "description": "Human-readable phase name",
            "examples": [
              "Foundation & Interfaces",
              "Core Push Functionality",
              "Testing & Integration"
            ]
          },
          "implementation_plan_path": {
            "type": "string",
            "description": "Path to phase implementation plan following R550 naming conventions (planning/phaseN/PHASE-IMPLEMENTATION-PLAN.md)",
            "pattern": "^planning/phase[0-9]+/PHASE-IMPLEMENTATION-PLAN\\.md$",
            "examples": [
              "planning/phase1/PHASE-IMPLEMENTATION-PLAN.md",
              "planning/phase2/PHASE-IMPLEMENTATION-PLAN.md"
            ]
          },
          "architecture_plan_path": {
            "type": "string",
            "description": "Path to phase architecture plan following R550 naming conventions (planning/phaseN/PHASE-ARCHITECTURE-PLAN.md)",
            "pattern": "^planning/phase[0-9]+/PHASE-ARCHITECTURE-PLAN\\.md$",
            "examples": [
              "planning/phase1/PHASE-ARCHITECTURE-PLAN.md",
              "planning/phase2/PHASE-ARCHITECTURE-PLAN.md"
            ]
          },
          "status": {
            "type": "string",
            "description": "Phase completion status",
            "enum": [
              "PLANNED",
              "IN_PROGRESS",
              "COMPLETE",
              "BLOCKED"
            ]
          },
          "test_plan_path": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional path to phase test plan",
            "pattern": "^planning/phase[0-9]+/PHASE-TEST-PLAN\\.md$"
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": [
        "object",
        "null"
      ],
      "description": "Tracks locations of all artifacts created during factory execution for instant discovery without filesystem searching (R340)",
      "properties": {
        "fix_plans": {
          "type": [
            "object",
            "null"
          ],
          "description": "Fix plans created by Code-Reviewer during CREATE_FIX_PLAN state",
          "additionalProperties": {
            "type": "object",
            "required": [
              "file_path",
              "created_at",
              "created_by",
              "artifact_type",
              "scope",
              "status"
            ],
            "properties": {
              "file_path": {
                "type": "string",
                "description": "Absolute or relative path to artifact file from project root"
              },
              "created_at": {
                "type": "string",
                "format": "date-time",
                "description": "ISO 8601 timestamp when artifact was created"
              },
              "created_by": {
                "type": "string",
                "description": "Agent that created this artifact",
                "enum": [
                  "code-reviewer",
                  "architect",
                  "orchestrator"
                ]
              },
              "artifact_type": {
                "type": "string",
                "description": "Type of artifact",
                "enum": [
                  "fix_plan",
                  "code_review",
                  "split_plan",
                  "integration_report",
                  "architecture_review"
                ]
              },
              "scope": {
                "type": "string",
                "description": "Scope of artifact (effort/wave/phase/project)",
                "enum": [
                  "effort",
                  "wave",
                  "phase",
                  "project"
                ]
              },
              "status": {
                "type": "string",
                "description": "Current status of artifact",
                "enum": [
                  "CREATED",
                  "READY",
                  "IN_USE",
                  "COMPLETED",
                  "ARCHIVED"
                ]
              },
              "related_bugs": {
                "type": [
                  "array",
                  "null"
                ],
                "description": "Bug IDs this artifact addresses",
