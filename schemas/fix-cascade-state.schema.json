{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://software-factory.dev/schemas/fix-cascade-state.schema.json",
  "title": "Software Factory 3.0 Fix Cascade State",
  "description": "Schema for fix-cascade-state.json - tracks fix cascade operations when bugs discovered in one iteration container require fixes in upstream containers, enabling convergence tracking across multiple integration levels",
  "type": "object",
  "required": [
    "cascade"
  ],
  "properties": {
    "cascade": {
      "type": "object",
      "description": "Active fix cascade operation tracking - manages multi-container bug fix propagation and convergence",
      "required": [
        "cascade_id",
        "cascade_status",
        "trigger_bug",
        "source_container",
        "affected_containers",
        "created_at",
        "convergence_tracking"
      ],
      "properties": {
        "cascade_id": {
          "type": "string",
          "description": "Unique identifier for this fix cascade operation",
          "pattern": "^CASCADE-[0-9]{3}-[A-Z_]+$",
          "examples": [
            "CASCADE-001-WAVE_1_TO_PHASE_1",
            "CASCADE-042-PHASE_2_TO_PROJECT"
          ]
        },
        "cascade_status": {
          "type": "string",
          "description": "Current status of the fix cascade operation",
          "enum": [
            "ACTIVE",
            "CONVERGING",
            "COMPLETED",
            "FAILED",
            "ESCALATED"
          ]
        },
        "trigger_bug": {
          "type": "object",
          "description": "Bug that triggered this cascade operation (reference to bug-tracking.json)",
          "required": [
            "bug_id",
            "severity",
            "discovered_in_container"
          ],
          "properties": {
            "bug_id": {
              "type": "string",
              "description": "Bug ID from bug-tracking.json",
              "pattern": "^BUG-[0-9]{3}-[A-Z_-]+$"
            },
            "severity": {
              "type": "string",
              "enum": [
                "CRITICAL",
                "HIGH",
                "MEDIUM",
                "LOW"
              ]
            },
            "discovered_in_container": {
              "type": "string",
              "description": "Container ID where bug was discovered (from integration-containers.json)"
            },
            "title": {
              "type": [
                "string",
                "null"
              ],
              "description": "Brief description of the bug"
            }
          }
        },
        "source_container": {
          "type": "object",
          "description": "Container where the cascade originated (where bug was discovered)",
          "required": [
            "container_id",
            "container_type",
            "iteration_when_discovered"
          ],
          "properties": {
            "container_id": {
              "type": "string",
              "description": "Container ID from integration-containers.json",
              "examples": [
                "wave_1_1",
                "phase_2",
                "project"
              ]
            },
            "container_type": {
              "type": "string",
              "enum": [
                "WAVE",
                "PHASE",
                "PROJECT"
              ]
            },
            "iteration_when_discovered": {
              "type": "integer",
              "description": "Which iteration of the source container was running when bug was discovered",
              "minimum": 1
            }
          }
        },
        "affected_containers": {
          "type": "array",
          "description": "Array of upstream containers that need fixes as part of this cascade",
          "items": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "container_id",
              "container_type",
              "fix_status",
              "priority_order"
            ],
            "properties": {
              "container_id": {
                "type": "string",
                "description": "Container ID that needs fixes"
              },
              "container_type": {
                "type": "string",
                "enum": [
                  "WAVE",
                  "PHASE",
                  "PROJECT"
                ]
              },
              "fix_status": {
                "type": "string",
                "description": "Status of fix in this container",
                "enum": [
                  "PENDING",
                  "IN_PROGRESS",
                  "FIXED",
                  "VERIFIED",
                  "REINTEGRATED",
                  "FAILED"
                ]
              },
              "priority_order": {
                "type": "integer",
                "description": "Order in which this container should be fixed (1=first, higher=later)",
                "minimum": 1
              },
              "fix_branch": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Git branch created for fix work in this container"
              },
              "assigned_agent": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Agent ID assigned to fix this container's issues"
              },
              "started_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time",
                "description": "ISO 8601 timestamp when fix work started in this container"
              },
              "completed_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time",
                "description": "ISO 8601 timestamp when fix work completed in this container"
              },
              "iteration_when_fixed": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "Which iteration of this container was running when fix completed",
                "minimum": 1
              },
              "bugs_fixed": {
                "type": [
                  "array",
                  "null"
                ],
                "description": "Bug IDs that were fixed in this container",
                "items": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "new_bugs_discovered": {
                "type": [
                  "array",
                  "null"
                ],
                "description": "New bug IDs discovered while fixing in this container",
                "items": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            }
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when this cascade was created"
        },
        "updated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "ISO 8601 timestamp when this cascade was last updated"
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "ISO 8601 timestamp when this cascade completed (only when cascade_status=COMPLETED)"
        },
        "convergence_tracking": {
          "type": "object",
          "description": "Metrics tracking convergence of the cascade toward completion",
          "required": [
            "total_containers_affected",
            "containers_fixed",
            "containers_remaining",
            "is_converging"
          ],
          "properties": {
            "total_containers_affected": {
              "type": "integer",
              "description": "Total number of containers affected by this cascade",
              "minimum": 1
            },
            "containers_fixed": {
              "type": "integer",
              "description": "Number of containers where fixes have been completed and verified",
              "minimum": 0
            },
            "containers_remaining": {
              "type": "integer",
              "description": "Number of containers still needing fixes",
              "minimum": 0
            },
            "total_bugs_in_cascade": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Total bugs that are part of this cascade (original + discovered during fixes)",
              "minimum": 1
            },
            "bugs_fixed_in_cascade": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Number of bugs fixed across all affected containers",
              "minimum": 0
            },
            "bugs_remaining_in_cascade": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Number of bugs still open in this cascade",
              "minimum": 0
            },
            "is_converging": {
              "type": "boolean",
              "description": "Whether the cascade is converging (bug count decreasing, containers being fixed)",
              "default": false
            },
            "convergence_confidence": {
              "type": [
                "string",
                "null"
              ],
              "description": "Confidence level in cascade completing successfully",
              "enum": [
                "HIGH",
                "MEDIUM",
                "LOW",
                "NONE",
                null
              ]
            },
            "estimated_completion_iterations": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Estimated iterations remaining until cascade completes",
              "minimum": 0
            },
            "cascade_depth": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Depth of cascade (number of container levels affected: 1=single level, 2=two levels, etc.)",
              "minimum": 1,
              "maximum": 3
            },
            "cascade_breadth": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Breadth of cascade (number of parallel containers affected at same level)",
              "minimum": 1
            }
          }
        },
        "cascade_path": {
          "type": [
            "array",
            "null"
          ],
          "description": "Ordered path showing the cascade flow from source to all affected containers",
          "items": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "step",
              "from_container",
              "to_container",
              "propagation_reason"
            ],
            "properties": {
              "step": {
                "type": "integer",
                "description": "Sequential step number in cascade path",
                "minimum": 1
              },
              "from_container": {
                "type": "string",
                "description": "Container ID where issue propagated from"
              },
              "to_container": {
                "type": "string",
                "description": "Container ID where issue propagated to"
              },
              "propagation_reason": {
                "type": "string",
                "description": "Why this propagation occurred",
                "examples": [
                  "Bug found in downstream integration requires upstream fix",
                  "Phase integration bug requires wave-level fix",
                  "Project integration bug requires phase-level fix"
                ]
              },
              "propagated_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time",
                "description": "When this propagation step was identified"
              }
            }
          }
        },
        "escalation_triggers": {
          "type": [
            "object",
            "null"
          ],
          "description": "Conditions that would trigger escalation to human intervention",
          "properties": {
            "max_cascade_depth_exceeded": {
              "type": [
                "boolean",
                "null"
              ],
              "description": "Whether cascade has exceeded maximum allowed depth",
              "default": false
            },
            "max_iterations_exceeded": {
              "type": [
                "boolean",
                "null"
              ],
              "description": "Whether any container has exceeded max iterations during cascade",
              "default": false
            },
            "non_converging_detected": {
              "type": [
                "boolean",
                "null"
              ],
              "description": "Whether cascade is not converging (bugs increasing instead of decreasing)",
              "default": false
            },
            "critical_bug_blocking": {
              "type": [
                "boolean",
                "null"
              ],
              "description": "Whether a critical bug is blocking cascade progress",
              "default": false
            },
            "escalation_required": {
              "type": [
                "boolean",
                "null"
              ],
              "description": "Whether escalation to human intervention is required",
              "default": false
            },
            "escalation_reason": {
              "type": [
                "string",
                "null"
              ],
              "description": "Human-readable reason for escalation (only set when escalation_required=true)"
            },
            "escalated_at": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time",
              "description": "ISO 8601 timestamp when escalation was triggered"
            }
          }
        },
        "return_state": {
          "type": [
            "string",
            "null"
          ],
          "description": "State in orchestrator-state-v3.json to return to when cascade completes",
          "examples": [
            "REVIEW_WAVE_INTEGRATION",
            "REVIEW_PHASE_INTEGRATION",
            "REVIEW_PROJECT_INTEGRATION"
          ]
        },
        "metadata": {
          "type": [
            "object",
            "null"
          ],
          "description": "Additional metadata about this cascade operation",
          "properties": {
            "cascade_type": {
              "type": [
                "string",
                "null"
              ],
              "description": "Type of cascade based on container levels involved",
              "enum": [
                "WAVE_TO_PHASE",
                "PHASE_TO_PROJECT",
                "WAVE_TO_PROJECT",
                "MULTI_WAVE",
                "MULTI_PHASE",
                null
              ]
            },
            "parent_cascade_id": {
              "type": [
                "string",
                "null"
              ],
              "description": "If this cascade was triggered by another cascade, the parent cascade ID"
            },
            "child_cascades": {
              "type": [
                "array",
                "null"
              ],
              "description": "Cascade IDs of any child cascades spawned from this one",
              "items": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "total_time_elapsed_hours": {
              "type": [
                "number",
                "null"
              ],
              "description": "Total time elapsed for this cascade operation (in hours)",
              "minimum": 0
            },
            "agents_involved": {
              "type": [
                "array",
                "null"
              ],
              "description": "List of agent IDs that worked on this cascade",
              "items": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "automation_level": {
              "type": [
                "string",
                "null"
              ],
              "description": "Level of automation achieved in this cascade",
              "enum": [
                "FULLY_AUTOMATED",
                "PARTIALLY_AUTOMATED",
                "MANUAL_INTERVENTION_REQUIRED",
                null
              ]
            }
          }
        }
      }
    },
    "cascade_history": {
      "type": [
        "array",
        "null"
      ],
      "description": "Archive of completed cascade operations for historical analysis",
      "items": {
        "type": [
          "object",
          "null"
        ],
        "description": "Same schema as cascade object, but for completed cascades",
        "properties": {
          "cascade_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "cascade_status": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "COMPLETED",
              "FAILED",
              "ESCALATED",
              null
            ]
          },
          "trigger_bug": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "bug_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "severity": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "created_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "completed_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "total_containers_affected": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "total_bugs_fixed": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "total_duration_hours": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "final_status": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "COMPLETED",
              "FAILED",
              "ESCALATED",
              null
            ]
          }
        }
      }
    },
    "statistics": {
      "type": [
        "object",
        "null"
      ],
      "description": "Statistical analysis of fix cascade operations across the project",
      "properties": {
        "total_cascades": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Total number of cascades initiated (active + completed)",
          "minimum": 0,
          "default": 0
        },
        "active_cascades": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of currently active cascades",
          "minimum": 0,
          "default": 0
        },
        "completed_cascades": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of successfully completed cascades",
          "minimum": 0,
          "default": 0
        },
        "failed_cascades": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of failed cascades",
          "minimum": 0,
          "default": 0
        },
        "escalated_cascades": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of cascades requiring human intervention",
          "minimum": 0,
          "default": 0
        },
        "average_cascade_depth": {
          "type": [
            "number",
            "null"
          ],
          "description": "Average depth of cascades (container levels affected)",
          "minimum": 1
        },
        "average_cascade_breadth": {
          "type": [
            "number",
            "null"
          ],
          "description": "Average breadth of cascades (parallel containers affected)",
          "minimum": 1
        },
        "average_cascade_duration_hours": {
          "type": [
            "number",
            "null"
          ],
          "description": "Average time to complete a cascade (in hours)",
          "minimum": 0
        },
        "average_bugs_per_cascade": {
          "type": [
            "number",
            "null"
          ],
          "description": "Average number of bugs involved in each cascade",
          "minimum": 1
        },
        "cascade_success_rate": {
          "type": [
            "number",
            "null"
          ],
          "description": "Percentage of cascades that completed successfully",
          "minimum": 0,
          "maximum": 100
        },
        "cascades_by_type": {
          "type": [
            "object",
            "null"
          ],
          "description": "Breakdown of cascades by type",
          "properties": {
            "wave_to_phase": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "phase_to_project": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "wave_to_project": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "multi_wave": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "multi_phase": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            }
          }
        }
      }
    },
    "metadata": {
      "type": [
        "object",
        "null"
      ],
      "description": "Metadata about the fix cascade state file",
      "properties": {
        "version": {
          "type": [
            "string",
            "null"
          ],
          "description": "Software Factory version",
          "default": "3.0.0"
        },
        "created_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "ISO 8601 timestamp when this file was created"
        },
        "last_updated": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "description": "ISO 8601 timestamp when this file was last updated"
        },
        "last_updated_by": {
          "type": [
            "string",
            "null"
          ],
          "description": "Agent that last updated this file",
          "default": "state-manager"
        },
        "schema_version": {
          "type": [
            "string",
            "null"
          ],
          "description": "Version of this schema",
          "default": "3.0.0"
        }
      }
    }
  }
}
