### 🔴🔴🔴 RULE R217 - MANDATORY RULE RELOADING ON STATE TRANSITION 🔴🔴🔴
**Source:** rule-library/R217-post-transition-rule-reacknowledgment.md
**Criticality:** MISSION CRITICAL - WITHOUT THIS, YOU WILL FORGET RULES AND FAIL

**AFTER EVERY STATE TRANSITION, YOU MUST RE-READ ALL RULES!**

```bash
# 🚨🚨🚨 THIS IS NOT OPTIONAL - YOU MUST DO THIS IMMEDIATELY! 🚨🚨🚨
perform_state_transition_with_mandatory_reload() {
    local OLD_STATE="$1"
    local NEW_STATE="$2"
    local SF_ROOT="${SF_ROOT:-/workspaces/software-factory-2.0-template}"
    
    echo "════════════════════════════════════════════════════════════════"
    echo "🔴 STATE TRANSITION: $OLD_STATE → $NEW_STATE"
    echo "════════════════════════════════════════════════════════════════"
    
    # STEP 1: Validate transition
    validate_state_transition "$OLD_STATE" "$NEW_STATE" "orchestrator"
    
    # STEP 2: Update state file
    update_state "current_state" "$NEW_STATE"
    
    # STEP 3: 🔴🔴🔴 MANDATORY RULE RELOADING 🔴🔴🔴
    echo ""
    echo "🔴🔴🔴 R217: MANDATORY RULE RELOADING NOW! 🔴🔴🔴"
    echo ""
    echo "I MUST USE THE READ TOOL ON THESE FILES IN ORDER:"
    echo ""
    echo "1️⃣ MY ORCHESTRATOR CONFIGURATION (THIS FILE):"
    echo "   READ NOW: ${SF_ROOT}/.claude/agents/orchestrator.md"
    # 🔴 STOP! USE READ TOOL ON THE FILE ABOVE BEFORE CONTINUING!
    
    echo ""
    echo "2️⃣ THE STATE MACHINE (DEFINES ALL VALID STATES):"
    echo "   READ NOW: ${SF_ROOT}/SOFTWARE-FACTORY-STATE-MACHINE.md"
    # 🔴 STOP! USE READ TOOL ON THE FILE ABOVE BEFORE CONTINUING!
    
    echo ""
    echo "3️⃣ STATE-SPECIFIC RULES FOR $NEW_STATE:"
    echo "   READ NOW: ${SF_ROOT}/agent-states/orchestrator/$NEW_STATE/rules.md"
    # 🔴 STOP! USE READ TOOL ON THE FILE ABOVE BEFORE CONTINUING!
    
    echo ""
    echo "4️⃣ CRITICAL SPAWNING RULES (IF SPAWNING STATE):"
    if [[ "$NEW_STATE" == *"SPAWN"* ]]; then
        echo "   READ NOW: ${SF_ROOT}/rule-library/R151-parallel-agent-spawning-timing.md"
        echo "   READ NOW: ${SF_ROOT}/rule-library/R218-orchestrator-parallel-code-reviewer-spawning.md"
        # 🔴 STOP! USE READ TOOL ON EACH FILE ABOVE!
    fi
    
    echo ""
    echo "⚠️⚠️⚠️ WARNING: IF YOU DON'T SEE READ TOOL OUTPUT ⚠️⚠️⚠️"
    echo "⚠️⚠️⚠️ ABOVE THIS LINE, YOU'RE VIOLATING R217! ⚠️⚠️⚠️"
    echo ""
    echo "After reading ALL files, I confirm:"
    echo "✅ I have USED READ TOOL (not just echoed paths)"
    echo "✅ My memory contains current rules"
    echo "✅ I understand my duties in state: $NEW_STATE"
    echo "════════════════════════════════════════════════════════════════"
    
    # STEP 4: Proceed with new state
    echo "Ready to execute $NEW_STATE activities"
}

# Use with EVERY transition:
perform_state_transition() {
    validate_state_transition "$1" "$2" "orchestrator"  # R206
    update_state "current_state" "$2"
    reacknowledge_critical_rules "$2"  # R217 - MUST READ FILES WITH READ TOOL!
    # After reacknowledge_critical_rules, orchestrator MUST have:
    # 1. Used Read tool on SOFTWARE-FACTORY-STATE-MACHINE.md
    # 2. Used Read tool on critical rule files (R151, R208, R209, etc.)
    # 3. Used Read tool on state-specific rules file
    # Only THEN can it proceed with new state work
}
```
