### RULE R001.0.0 - Pre-Flight Checks
**Source:** rule-library/RULE-REGISTRY.md#R001  
**Criticality:** BLOCKING - Failure = Immediate Stop (exit 1)

```bash
echo "═══════════════════════════════════════════════════════════════"
echo "🚨 MANDATORY PRE-FLIGHT CHECKS STARTING 🚨"
echo "═══════════════════════════════════════════════════════════════"
echo "AGENT STARTUP: $(date '+%Y-%m-%d %H:%M:%S %Z')"
echo "AGENT: orchestrator"
echo "═══════════════════════════════════════════════════════════════"

# CHECK 0: AUTOMATIC COMPACTION DETECTION (MANDATORY FIRST CHECK!)
echo "Checking for compaction marker..."
# Use the check-compaction-agent.sh utility script
if [ -f "$HOME/.claude/utilities/check-compaction-agent.sh" ]; then 
    bash "$HOME/.claude/utilities/check-compaction-agent.sh" orchestrator; 
elif [ -f "/home/user/.claude/utilities/check-compaction-agent.sh" ]; then 
    bash "/home/user/.claude/utilities/check-compaction-agent.sh" orchestrator; 
elif [ -f "./utilities/check-compaction-agent.sh" ]; then 
    bash "./utilities/check-compaction-agent.sh" orchestrator; 
else 
    echo "⚠️ Compaction check script not found, using fallback"; 
    if [ -f /tmp/compaction_marker.txt ]; then echo "COMPACTION DETECTED"; cat /tmp/compaction_marker.txt; rm -f /tmp/compaction_marker.txt; echo "RECOVER TODOs NOW"; exit 0; else echo "No compaction detected"; fi; 
fi

# The old inline version with backslashes has been removed.
# It caused syntax errors when agents ran it as a single line.
# Now using the check-compaction-agent.sh utility script instead.

# CHECK 1: VERIFY WORKING DIRECTORY
echo "Checking working directory..."
pwd
# For orchestrator, we expect to be in project root with orchestrator-state.yaml
if [[ ! -f "./orchestrator-state.yaml" ]]; then 
    echo "❌ FAIL - Cannot find orchestrator-state.yaml"; 
    echo "❌ STOPPING IMMEDIATELY - WRONG DIRECTORY"; 
    exit 1; 
fi
echo "✅ PASS - Correct directory"

# CHECK 2: VERIFY GIT BRANCH
echo "Checking Git branch..."
CURRENT_BRANCH=$(git branch --show-current)
echo "Current branch: $CURRENT_BRANCH"
# Orchestrator works on main or integration branches
if [[ "$CURRENT_BRANCH" != "main" && "$CURRENT_BRANCH" != *"integration"* ]]; then 
    echo "⚠️ WARNING - Unusual branch for orchestrator"; 
fi

# CHECK 3: CHECK GIT STATUS
echo "Checking Git status..."
if [[ -z $(git status --porcelain) ]]; then 
    echo "✅ CLEAN - No uncommitted changes"; 
else 
    echo "⚠️ WARNING - Uncommitted changes present"; 
    git status --short; 
fi

# CHECK 4: VERIFY REMOTE TRACKING
echo "Checking remote configuration..."
if git remote -v | grep -q origin; then 
    echo "✅ REMOTE OK"; 
else 
    echo "⚠️ NO REMOTE - May need to configure"; 
fi

echo "═══════════════════════════════════════════════════════════════"
echo "PRE-FLIGHT CHECKS COMPLETE"
echo "═══════════════════════════════════════════════════════════════"
```
