**YOU ARE THE MASTER OF ALL DIRECTORY STRUCTURES:**
```bash
# 🚨 ORCHESTRATOR DEFINES ALL PATHS - AGENTS MUST FOLLOW! 🚨
inject_wave_metadata() {
    local PHASE="$1"
    local WAVE="$2"
    local WAVE_ARCH_PLAN="phase-plans/PHASE-${PHASE}-WAVE-${WAVE}-ARCHITECTURE-PLAN.md"
    local WAVE_IMPL_PLAN="phase-plans/PHASE-${PHASE}-WAVE-${WAVE}-IMPLEMENTATION-PLAN.md"
    
    echo "═══════════════════════════════════════════════════════"
    echo "🌊 R213: ORCHESTRATOR DEFINING Wave ${WAVE} Structure"
    echo "═══════════════════════════════════════════════════════"
    
    # ORCHESTRATOR DECIDES ALL PATHS!
    local PROJECT_ROOT="$(pwd)"
    local WAVE_ROOT="${PROJECT_ROOT}/efforts/phase${PHASE}/wave${WAVE}"
    local EFFORT_COUNT=$(ls -d ${WAVE_ROOT}/effort-* 2>/dev/null | wc -l || echo "0")
    
    # Function to inject authoritative metadata
    inject_into_wave_plan() {
        local PLAN="$1"
        [ ! -f "$PLAN" ] && return 1
        
        grep -q "WAVE INFRASTRUCTURE METADATA" "$PLAN" && return 0
        
        cat > /tmp/wave_metadata.md << EOF
<!-- ⚠️ WAVE INFRASTRUCTURE METADATA (R213 - ORCHESTRATOR DEFINED) ⚠️ -->
<!-- 🚨 THIS IS THE AUTHORITATIVE DIRECTORY STRUCTURE 🚨 -->
**METADATA_SOURCE**: ORCHESTRATOR (Single Source of Truth)
**GENERATED_AT**: $(date -Iseconds)
**PHASE_NUMBER**: ${PHASE}
**WAVE_NUMBER**: ${WAVE}
**WAVE_ROOT**: ${WAVE_ROOT}
**EFFORT_COUNT**: ${EFFORT_COUNT}
**INTEGRATION_BRANCH**: phase${PHASE}/wave${WAVE}-integration

## Orchestrator-Defined Structure
\`\`\`
${WAVE_ROOT}/
├── effort-1/     # Contracts (ALWAYS FIRST)
├── effort-2/     # Libraries
├── effort-3/     # Feature (PARALLEL)
├── effort-4/     # Feature (PARALLEL)
└── effort-5/     # Integration
\`\`\`

⚠️ **AGENTS MUST USE THESE EXACT PATHS!** ⚠️
<!-- END WAVE METADATA -->

EOF
        
        cat /tmp/wave_metadata.md "$PLAN" > /tmp/updated_plan.md
        mv /tmp/updated_plan.md "$PLAN"
        echo "✅ R213: Authoritative structure injected into $PLAN"
    }
    
    # Inject into all wave plans
    inject_into_wave_plan "$WAVE_ARCH_PLAN"
    inject_into_wave_plan "$WAVE_IMPL_PLAN"
    
    echo "🔒 Wave ${WAVE} structure LOCKED by orchestrator"
}

# When creating efforts, ensure consistency with wave metadata
create_effort_with_consistent_metadata() {
    local PHASE="$1" WAVE="$2" EFFORT="$3" EFFORT_NUM="$4"
    
    # Use SAME paths as in wave metadata!
    local WAVE_ROOT="$(pwd)/efforts/phase${PHASE}/wave${WAVE}"
    local EFFORT_DIR="${WAVE_ROOT}/effort-${EFFORT_NUM}"
    
    mkdir -p "$EFFORT_DIR/pkg"
    cd "$EFFORT_DIR"
    
    # Create branch (orchestrator controls ALL naming!)
    git checkout -b "phase${PHASE}/wave${WAVE}/effort-${EFFORT_NUM}"
    
    # Files with R209 metadata that MATCHES R213 structure
    touch IMPLEMENTATION-PLAN.md work-log.md
    inject_r209_metadata "$EFFORT" "$PHASE" "$WAVE"
    
    echo "✅ Effort created with R213-consistent structure"
}
```

**CRITICAL WORKFLOW:**
1. Orchestrator creates wave directory structure
2. **INJECT R213 METADATA** into wave plans (YOU define paths!)
3. Agents read YOUR metadata and follow YOUR structure
4. No agent creates directories - they use YOURS

