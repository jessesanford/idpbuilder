  "fundamental_laws": {
    "state_transition_stop": {
      "rule": "FUNDAMENTAL LAW",
      "description": "Each state does ONE atomic operation. After completing that operation, the agent MUST STOP. State transitions are NEVER automatic.",
      "requirements": [
        "Enter state",
        "Perform ONE TYPE of operation",
        "Update state file",
        "STOP",
        "Wait for continuation"
      ]
    },
    "parallelization_allowed": {
      "rule": "R151",
      "description": "Multiple agents of the SAME TYPE in parallel are allowed",
      "requirements": [
        "Same agent type",
        "Same phase",
        "Same purpose",
        "Timing delta <5s between spawns"
      ]
    },
    "phase_mixing_forbidden": {
      "description": "Spawning different agent types or mixing phases is FORBIDDEN",
      "penalty": "AUTOMATIC -100% FAILURE",
      "examples": [
        "Spawning agent then immediately monitoring them",
        "Getting review results then immediately spawning fixes",
        "Spawning Code Reviewer then immediately spawning SW Engineer",
        "Any flow through behavior across phase boundaries"
      ]
    }
  },
  "supreme_laws": [
    {
      "rule": "R233",
      "title": "ALL STATES REQUIRE IMMEDIATE ACTION",
      "description": "States are VERBS, not destinations! Every state name is a command to execute.",
      "requirements": [
        "Upon entering ANY state, MUST immediately perform that action",
        "NO announcements about being in a state",
        "NO waiting or pausing after state entry",
        "ONLY terminal states may stop execution"
      ]
    },
    {
      "rule": "R313",
      "title": "MANDATORY STOP AFTER SPAWNING AGENTS",
      "description": "Context preservation law - prevents rule loss",
      "spawn_states_requiring_stop": [
        "SPAWN_AGENTS",
        "SPAWN_CODE_REVIEWERS_EFFORT_PLANNING",
        "SPAWN_CODE_REVIEWERS_FOR_REVIEW",
        "SPAWN_ENGINEERS_FOR_FIXES",
        "SPAWN_INTEGRATION_AGENT",
        "SPAWN_ARCHITECT_*",
        "SPAWN_CODE_REVIEWER_*"
      ]
    },
    {
      "rule": "R322",
      "title": "MANDATORY CHECKPOINT BEFORE STATE TRANSITIONS",
      "description": "User review law - ensures plan approval before execution",
      "checkpoint_transitions": [
        {
          "from": "WAITING_FOR_MERGE_PLAN",
          "to": "SPAWN_INTEGRATION_AGENT",
          "reason": "Review merge plan before execution"
        },
        {
          "from": "WAITING_FOR_PHASE_MERGE_PLAN",
          "to": "SPAWN_INTEGRATION_AGENT_PHASE",
          "reason": "Review phase plan"
        },
        {
          "from": "WAITING_FOR_PROJECT_MERGE_PLAN",
          "to": "SPAWN_INTEGRATION_AGENT_PROJECT",
          "reason": "Review project plan"
        },
        {
          "from": "WAITING_FOR_FIX_PLANS",
          "to": "DISTRIBUTE_FIX_PLANS",
          "reason": "Review fix strategy"
        },
        {
          "from": "WAITING_FOR_BACKPORT_PLAN",
          "to": "SPAWN_SW_ENGINEER_BACKPORT_FIXES",
          "reason": "Review backports"
        }
      ]
    },
    {
      "rule": "R336",
      "title": "MANDATORY WAVE INTEGRATION BEFORE NEXT WAVE",
      "description": "Trunk-based development law - each wave builds on integrated previous wave",
      "requirements": [
        "WAVE_COMPLETE → INTEGRATION is MANDATORY",
        "Wave N integration branch becomes base for Wave N+1",
        "NO wave may start without previous wave's integration branch",
        "Architect reviews INTEGRATED wave, not individual efforts"
      ]
    },
    {
      "rule": "R321",
      "title": "IMMEDIATE BACKPORT DURING INTEGRATION",
      "description": "All fixes during integration must be immediately backported to source branches",
      "requirements": [
        "Integration branches are READ-ONLY for code",
        "ANY fix triggers IMMEDIATE_BACKPORT_REQUIRED state",
        "Source branches must be fixed BEFORE continuing",
        "Deferred backporting is DEPRECATED"
      ]
    },
    {
      "rule": "R234",
      "title": "MANDATORY STATE TRAVERSAL - NO SKIPPING",
      "description": "Highest law - supersedes all other rules",
      "mandatory_sequence": [
        "CREATE_NEXT_INFRASTRUCTURE",
        "VALIDATE_INFRASTRUCTURE",
        "ANALYZE_CODE_REVIEWER_PARALLELIZATION",
        "SPAWN_CODE_REVIEWERS_EFFORT_PLANNING",
        "WAITING_FOR_EFFORT_PLANS",
        "ANALYZE_IMPLEMENTATION_PARALLELIZATION",
        "SPAWN_AGENTS"
      ],
      "forbidden_transitions": [
        "CREATE_NEXT_INFRASTRUCTURE → SPAWN_AGENTS (without validation)",
        "CREATE_NEXT_INFRASTRUCTURE → ANALYZE_IMPLEMENTATION_PARALLELIZATION (without validation)"
      ]
    }
  ],
  "optimization_rules": [
    {
      "rule": "R356",
      "title": "SINGLE-EFFORT OPTIMIZATION EXCEPTION",
      "description": "Performance optimization for single-effort waves",
      "allowed_optimizations": [
        {
          "condition": "Single effort detected",
          "from": "CREATE_NEXT_INFRASTRUCTURE",
          "to": "SPAWN_CODE_REVIEWERS_EFFORT_PLANNING",
          "skip": "ANALYZE_CODE_REVIEWER_PARALLELIZATION"
        },
        {
          "condition": "Single effort detected",
          "from": "WAITING_FOR_EFFORT_PLANS",
          "to": "SPAWN_AGENTS",
          "skip": "ANALYZE_IMPLEMENTATION_PARALLELIZATION"
        }
      ],
      "requirements": [
        "MUST verify single effort",
        "MUST document optimization",
        "MUST save minimal plan with r356_applied flag",
        "Early exit in analysis states if entered with 1 effort"
      ]
    }
  ],
