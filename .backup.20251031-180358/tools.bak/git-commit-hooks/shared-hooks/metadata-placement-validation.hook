#!/bin/bash
# R383 & R343 Software Factory Metadata Placement Enforcement Hook
# Ensures ALL Software Factory metadata is in .software-factory/ directories
# SUPREME LAW - Violations cause merge conflicts and pollute production PRs
# Exit code 383 on violations

set -euo pipefail

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

print_error() {
    echo -e "${RED}${BOLD}🔴 R383 VIOLATION:${NC} ${RED}$1${NC}" >&2
}

print_success() {
    echo -e "${GREEN}✅ R383 COMPLIANT:${NC} ${GREEN}$1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  R383 WARNING:${NC} ${YELLOW}$1${NC}"
}

print_info() {
    echo -e "${BLUE}ℹ️  INFO:${NC} $1"
}

# Get git root and staged files
GIT_ROOT="$(git rev-parse --show-toplevel)"
cd "$GIT_ROOT"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")

if [ -z "$STAGED_FILES" ]; then
    print_success "No files staged for commit"
    exit 0
fi

# Check for escape hatch
if [ -f "$GIT_ROOT/.sf-metadata-override" ]; then
    print_warning "Metadata placement check overridden by .sf-metadata-override"
    print_warning "This should only be used in EXCEPTIONAL circumstances!"
    exit 0
fi

# Function to determine if file is Software Factory metadata
is_sf_metadata() {
    local file="$1"
    local filename=$(basename "$file")
    local dirname=$(dirname "$file")
    local extension="${filename##*.}"

    # First: Exclude files that are NEVER metadata (legitimate project files)

    # Standard project documentation
    case "$filename" in
        README.md|CONTRIBUTING.md|LICENSE.md|LICENSE|CHANGELOG.md|CODE_OF_CONDUCT.md|\
        SECURITY.md|ADOPTERS.md|AUTHORS.md|MAINTAINERS.md)
            return 1  # Not metadata
            ;;
    esac

    # Dependency management files
    case "$filename" in
        go.mod|go.sum|package.json|package-lock.json|yarn.lock|pnpm-lock.yaml|\
        requirements.txt|Pipfile|Pipfile.lock|poetry.lock|Cargo.toml|Cargo.lock|\
        Gemfile|Gemfile.lock|build.gradle|pom.xml|composer.json|composer.lock)
            return 1  # Not metadata
            ;;
    esac

    # Configuration files
    case "$filename" in
        .gitignore|.dockerignore|.editorconfig|.prettierrc*|.eslintrc*|.pylintrc|\
        .flake8|.rubocop.yml|tsconfig.json|jest.config.*|webpack.config.*|\
        babel.config.*|.nvmrc|.python-version|.ruby-version)
            return 1  # Not metadata
            ;;
    esac

    # Build and infrastructure files
    case "$filename" in
        Makefile|Dockerfile|docker-compose*.yml|*.mk|Vagrantfile|Jenkinsfile|\
        .gitlab-ci.yml|.travis.yml|.circleci/*)
            return 1  # Not metadata
            ;;
    esac

    # Exclude files in legitimate project directories
    if [[ "$dirname" =~ ^(docs|documentation|\.github|pkg|cmd|src|lib|internal|api|test|tests|examples)(/|$) ]]; then
        return 1  # Not metadata - in project directories
    fi

    # Exclude actual source code files
    case "$extension" in
        go|py|js|ts|jsx|tsx|java|rs|rb|php|c|cpp|h|hpp|cs|swift|kt|scala|\
        html|css|scss|sass|less|sql|sh|bash|zsh|fish)
            return 1  # Not metadata - source code
            ;;
    esac

    # Now: Detect Software Factory metadata patterns

    # Explicit SF metadata file patterns (high confidence)
    case "$filename" in
        IMPLEMENTATION-PLAN*|EFFORT-PLAN*|WAVE-PLAN*|PHASE-PLAN*|\
        SPLIT-PLAN*|FIX-PLAN*|INTEGRATION-PLAN*|ARCHITECTURE-PLAN*|\
        CODE-REVIEW-REPORT*|REVIEW-REPORT*|SPLIT-REVIEW*|\
        FIX-SUMMARY*|FIX-INSTRUCTIONS*|VIOLATION-REPORT*|\
        INTEGRATION-REPORT*|WAVE-MERGE-PLAN*|PHASE-MERGE-PLAN*|\
        WAVE-INTEGRATION-REPORT*|PHASE-INTEGRATION-REPORT*|\
        ARCHITECT-PROMPT*|ASSESSMENT-REPORT*|ANALYSIS-REPORT*|\
        work-log*|validation-results*|review-*.md|\
        *-COMPLETE.marker|*-STATUS.marker|*.marker|\
        *TODO*.md|split-metadata.json|effort-metadata.json|\
        orchestrator-state*.json|state-marker*)
            return 0  # Definitely metadata
            ;;
    esac

    # Keyword detection in filename (medium confidence)
    if [[ "$filename" =~ (PLAN|REVIEW|REPORT|SPLIT|FIX|VIOLATION|ANALYSIS|ASSESSMENT|ARCHITECTURE) ]]; then
        # Additional check: is it a .md file?
        if [[ "$extension" == "md" ]]; then
            return 0  # Likely metadata
        fi
    fi

    # Work tracking files
    if [[ "$filename" =~ work-log ]] || [[ "$file" =~ \.log$ && "$dirname" != "logs" ]]; then
        return 0  # Metadata
    fi

    # Marker files
    if [[ "$file" =~ \.marker$ ]]; then
        return 0  # Metadata
    fi

    # TODO tracking
    if [[ "$file" =~ ^todos/ ]] || [[ "$file" =~ \.todo$ ]]; then
        return 0  # Metadata
    fi

    # .md files in effort root (not in subdirs) are likely metadata
    # This catches planning docs that don't follow naming conventions
    if [[ "$file" =~ ^efforts/[^/]+/[^/]+/[^/]+/[^/]+\.md$ ]]; then
        # File is in effort root: efforts/phaseX/waveY/effort-name/file.md
        # These are likely SF metadata unless explicitly project docs
        case "$filename" in
            README.md|CONTRIBUTING.md)
                return 1  # Legitimate project docs even in effort root
                ;;
            *)
                return 0  # Probably metadata
                ;;
        esac
    fi

    # Default: not metadata
    return 1
}

# Function to detect correct .software-factory location for a file
get_correct_location() {
    local file="$1"
    local current_dir=$(dirname "$file")

    # Try to detect phase/wave/effort from current path
    if [[ "$current_dir" =~ efforts/phase([0-9]+)/wave([0-9]+)/([^/]+) ]]; then
        local phase="${BASH_REMATCH[1]}"
        local wave="${BASH_REMATCH[2]}"
        local effort="${BASH_REMATCH[3]}"

        # Check if it's a split
        if [[ "$effort" =~ (.+)--split-([0-9]+) ]]; then
            local base_effort="${BASH_REMATCH[1]}"
            local split_num="${BASH_REMATCH[2]}"
            echo ".software-factory/phase${phase}/wave${wave}/${effort}/"
        else
            echo ".software-factory/phase${phase}/wave${wave}/${effort}/"
        fi
        return
    fi

    # Check for integration workspaces
    if [[ "$current_dir" =~ efforts/phase([0-9]+)/wave([0-9]+)-integration ]]; then
        local phase="${BASH_REMATCH[1]}"
        local wave="${BASH_REMATCH[2]}"
        echo ".software-factory/phase${phase}/wave${wave}/integration/"
        return
    fi

    if [[ "$current_dir" =~ efforts/phase([0-9]+)-integration ]]; then
        local phase="${BASH_REMATCH[1]}"
        echo ".software-factory/phase${phase}/integration/"
        return
    fi

    # Try to detect from current branch name
    local current_branch=$(git branch --show-current 2>/dev/null || echo "")
    if [[ "$current_branch" =~ phase([0-9]+)/wave([0-9]+)/([^/]+) ]]; then
        local phase="${BASH_REMATCH[1]}"
        local wave="${BASH_REMATCH[2]}"
        local effort="${BASH_REMATCH[3]}"
        echo ".software-factory/phase${phase}/wave${wave}/${effort}/"
        return
    fi

    # Check for project-level metadata locations (these are OK)
    if [[ "$current_dir" =~ ^(phase-plans|phase-assessments|protocols|templates)(/|$) ]]; then
        echo "ALLOWED_LOCATION"
        return
    fi

    # Default: suggest phase1/wave1 if we can't determine
    echo ".software-factory/phase1/wave1/UNKNOWN-EFFORT/"
}

# Function to check if file has timestamp suffix
has_timestamp() {
    local filename=$(basename "$1")

    # Some files don't need timestamps
    case "$filename" in
        orchestrator-state-v3.json|target-repo-config.yaml|split-metadata.json|\
        effort-metadata.json|.gitignore)
            return 0  # Exempt from timestamp requirement
            ;;
    esac

    # Check for --YYYYMMDD-HHMMSS pattern
    if [[ "$filename" =~ --[0-9]{8}-[0-9]{6}\. ]]; then
        return 0  # Has timestamp
    fi

    return 1  # Missing timestamp
}

# Main validation logic
VIOLATIONS=0
VIOLATION_FILES=()
VIOLATION_MESSAGES=()

echo ""
echo -e "${BOLD}🔍 R383 Software Factory Metadata Placement Validation${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

while IFS= read -r file; do
    # Skip if file doesn't exist (deleted files)
    [ -f "$file" ] || continue

    # Check if it's SF metadata
    if is_sf_metadata "$file"; then
        filename=$(basename "$file")

        # Check if file is in .software-factory directory
        if [[ ! "$file" =~ \.software-factory/ ]]; then
            # Determine correct location
            correct_location=$(get_correct_location "$file")

            # If this is an allowed location, skip
            if [ "$correct_location" = "ALLOWED_LOCATION" ]; then
                continue
            fi

            VIOLATIONS=$((VIOLATIONS + 1))
            VIOLATION_FILES+=("$file")
            VIOLATION_MESSAGES+=("❌ $file
   ${RED}→ MUST be in: ${correct_location}${NC}")
            continue
        fi

        # Check if file has required timestamp
        if ! has_timestamp "$file"; then
            VIOLATIONS=$((VIOLATIONS + 1))
            VIOLATION_FILES+=("$file")
            VIOLATION_MESSAGES+=("⚠️  $file
   ${YELLOW}→ Missing timestamp suffix: --YYYYMMDD-HHMMSS${NC}")
        fi
    fi
done <<< "$STAGED_FILES"

# Report results
echo ""
if [ $VIOLATIONS -eq 0 ]; then
    print_success "All Software Factory metadata properly placed!"
    echo -e "${GREEN}  ✓ All metadata in .software-factory/ directories${NC}"
    echo -e "${GREEN}  ✓ All metadata files have timestamps${NC}"
    echo -e "${GREEN}  ✓ No metadata pollution in project codebase${NC}"
    echo ""
    exit 0
fi

# Print violations
echo -e "${RED}${BOLD}🚨🚨🚨 SOFTWARE FACTORY METADATA MISPLACEMENT DETECTED! 🚨🚨🚨${NC}"
echo ""
echo -e "${RED}Found ${VIOLATIONS} violations:${NC}"
echo ""

for msg in "${VIOLATION_MESSAGES[@]}"; do
    echo -e "$msg"
    echo ""
done

# Print detailed fix instructions
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BOLD}📋 HOW TO FIX THESE VIOLATIONS:${NC}"
echo ""

for file in "${VIOLATION_FILES[@]}"; do
    if [[ ! "$file" =~ \.software-factory/ ]]; then
        filename=$(basename "$file")
        correct_location=$(get_correct_location "$file")

        if [ "$correct_location" != "ALLOWED_LOCATION" ]; then
            # Generate timestamped filename if missing
            if ! has_timestamp "$file"; then
                timestamp=$(date +%Y%m%d-%H%M%S)
                name_without_ext="${filename%.*}"
                ext="${filename##*.}"
                new_filename="${name_without_ext}--${timestamp}.${ext}"
            else
                new_filename="$filename"
            fi

            echo -e "${YELLOW}Fix for: ${file}${NC}"
            echo -e "${GREEN}# Create directory and move file:${NC}"
            echo "  mkdir -p ${correct_location}"
            echo "  git rm --cached ${file}"
            echo "  mv ${file} ${correct_location}${new_filename}"
            echo "  git add ${correct_location}${new_filename}"
            echo ""
        fi
    elif ! has_timestamp "$file"; then
        filename=$(basename "$file")
        dirname=$(dirname "$file")
        timestamp=$(date +%Y%m%d-%H%M%S)
        name_without_ext="${filename%.*}"
        ext="${filename##*.}"
        new_filename="${name_without_ext}--${timestamp}.${ext}"

        echo -e "${YELLOW}Fix for: ${file}${NC}"
        echo -e "${GREEN}# Add timestamp suffix:${NC}"
        echo "  git rm --cached ${file}"
        echo "  mv ${file} ${dirname}/${new_filename}"
        echo "  git add ${dirname}/${new_filename}"
        echo ""
    fi
done

echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "${RED}${BOLD}🔴🔴🔴 WHY THIS MATTERS: 🔴🔴🔴${NC}"
echo -e "${RED}1. Keeps your software project CLEAN and professional${NC}"
echo -e "${RED}2. Prevents SF metadata from polluting production PRs${NC}"
echo -e "${RED}3. Avoids merge conflicts from parallel effort metadata${NC}"
echo -e "${RED}4. Maintains clear separation between work and deliverables${NC}"
echo ""
echo -e "${YELLOW}📖 References:${NC}"
echo -e "   - rule-library/R383-metadata-file-timestamp-requirements.md"
echo -e "   - rule-library/R343-metadata-directory-standardization.md"
echo ""
echo -e "${RED}${BOLD}⚠️  R383 SUPREME LAW PENALTY: -30% per violation, -100% for systemic pollution${NC}"
echo ""
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
exit 383
