#!/bin/bash

# STRICT Pre-commit hook for Software Factory 2.0 - Planning Repository Branch Validation
# This hook STRICTLY enforces that ONLY the software-factory-2.0 branch can be used
# in planning repositories to prevent code contamination
#
# RULE: Planning repositories are for PLANS ONLY - NO CODE ALLOWED!

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Get the git root directory
GIT_ROOT="$(git rev-parse --show-toplevel)"
cd "$GIT_ROOT"

# Function to print colored messages
print_error() {
    echo -e "${RED}${BOLD}❌ ERROR:${NC} ${RED}$1${NC}" >&2
}

print_success() {
    echo -e "${GREEN}${BOLD}✅ SUCCESS:${NC} ${GREEN}$1${NC}"
}

print_info() {
    echo -e "${BLUE}${BOLD}ℹ️  INFO:${NC} $1"
}

# Main validation logic
main() {
    # NOTE: Branch validation is ONLY enforced in project repositories.
    # The template repository allows multiple branches for development and maintenance.

    # Skip validation if this is the template repository (has .template-repository marker)
    if [ -f "$GIT_ROOT/.template-repository" ]; then
        print_success "Template repository detected - branch validation skipped"
        exit 0
    fi

    # Skip validation if no target-repo-config.yaml exists (not a configured project)
    # This catches cases where someone is using the template for learning/testing
    if [ ! -f "$GIT_ROOT/target-repo-config.yaml" ]; then
        print_info "No target-repo-config.yaml - skipping strict branch validation"
        exit 0
    fi

    # Skip validation if SKIP_BRANCH_VALIDATION is set (for emergency use only)
    if [ "${SKIP_BRANCH_VALIDATION:-}" = "true" ]; then
        print_error "WARNING: Branch validation skipped - this should only be used in emergencies!"
        exit 0
    fi

    # Get current branch
    local current_branch="$(git branch --show-current)"

    # Skip if we're in a detached HEAD state
    if [ -z "$current_branch" ]; then
        exit 0
    fi

    # STRICT ENFORCEMENT: Only allow software-factory-2.0 or main (for initial setup)
    if [ "$current_branch" = "software-factory-2.0" ]; then
        print_success "Branch 'software-factory-2.0' is the correct branch for planning work"
        exit 0
    fi

    # Allow main ONLY if there's no PROJECT-IMPLEMENTATION-PLAN.md yet (initial setup)
    if [ "$current_branch" = "main" ] && [ ! -f "$GIT_ROOT/PROJECT-IMPLEMENTATION-PLAN.md" ]; then
        print_info "Branch 'main' allowed for initial repository setup"
        exit 0
    fi

    # ALL OTHER BRANCHES ARE STRICTLY FORBIDDEN!
    echo ""
    echo -e "${RED}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}${BOLD}                    🚨 BRANCH VIOLATION DETECTED! 🚨                 ${NC}"
    echo -e "${RED}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${RED}${BOLD}WRONG! YOU ARE ON THE PLANNING REPO, YOU MUST NOT SUBMIT ANY CODE${NC}"
    echo -e "${RED}${BOLD}OR WORK OTHER THAN PLANS TO THIS REPO!${NC}"
    echo ""
    echo -e "${RED}Current branch: ${BOLD}${current_branch}${NC}"
    echo ""
    echo -e "${YELLOW}${BOLD}MOVE YOUR CODE OR OTHER CHANGES TO THE APPROPRIATE EFFORT DIRECTORY${NC}"
    echo -e "${YELLOW}(located under \$CLAUDE_PROJECT_DIR/efforts/phaseX/waveY/**/*)${NC}"
    echo -e "${YELLOW}OR THE APPROPRIATE INTEGRATION DIRECTORY${NC}"
    echo -e "${YELLOW}(under \$CLAUDE_PROJECT_DIR/efforts/**/integration)${NC}"
    echo -e "${YELLOW}AND THE APPROPRIATE BRANCH ON THE TARGET REPO.${NC}"
    echo ""
    echo -e "${BLUE}SEE THE \$CLAUDE_PROJECT_DIR/target-repo-config.yaml FOR THE CURRENT TARGET REPO INFO!${NC}"
    echo ""
    echo -e "${RED}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${BOLD}THE ONLY ALLOWED BRANCH IN THIS PLANNING REPOSITORY IS:${NC}"
    echo -e "${GREEN}  • software-factory-2.0${NC} - For all Software Factory planning work"
    echo -e "${GREEN}  • main${NC} - ONLY for initial repository setup (before PROJECT-IMPLEMENTATION-PLAN.md exists)"
    echo ""
    echo -e "${RED}${BOLD}This repository detected ${YELLOW}361 inappropriate branches${RED} with implementation code!${NC}"
    echo -e "${RED}${BOLD}DO NOT CREATE ANY MORE! Use the proper effort directories instead.${NC}"
    echo ""
    echo -e "${RED}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    # Exit with error - BLOCK THE COMMIT!
    exit 1
}

# Run main function
main "$@"