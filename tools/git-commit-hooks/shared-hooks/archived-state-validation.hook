#!/bin/bash
# Pre-commit hook: Validate No ARCHIVED States
# CRITICAL: ARCHIVED states should NEVER exist in active projects
# This hook prevents accidental commits of ARCHIVED state directories

# Find any ARCHIVED directories in agent-states
ARCHIVED_DIRS=$(find agent-states -type d -name "ARCHIVED" 2>/dev/null)

if [ -n "$ARCHIVED_DIRS" ]; then
    echo "❌❌❌ COMMIT BLOCKED: ARCHIVED STATE CONTAMINATION DETECTED ❌❌❌"
    echo ""
    echo "ARCHIVED state directories found:"
    echo "$ARCHIVED_DIRS" | sed 's/^/  - /'
    echo ""
    echo "CRITICAL: ARCHIVED states should NEVER exist in active projects!"
    echo "These directories must be removed before committing."
    echo ""
    echo "To fix:"
    echo "  rm -rf agent-states/ARCHIVED"
    echo "  # Or remove specific ARCHIVED subdirectories"
    echo ""
    echo "WHY THIS MATTERS:"
    echo "  - ARCHIVED states are deprecated/obsolete"
    echo "  - They can confuse agents trying to read rules"
    echo "  - They violate rule synchronization requirements"
    echo "  - They contaminate the codebase with dead code"
    echo ""
    exit 1
fi

# Also check for any files being staged in ARCHIVED directories
STAGED_ARCHIVED=$(git diff --cached --name-only | grep "agent-states/.*ARCHIVED" || true)

if [ -n "$STAGED_ARCHIVED" ]; then
    echo "❌❌❌ COMMIT BLOCKED: ATTEMPTING TO STAGE ARCHIVED STATE FILES ❌❌❌"
    echo ""
    echo "Files in ARCHIVED directories:"
    echo "$STAGED_ARCHIVED" | sed 's/^/  - /'
    echo ""
    echo "ARCHIVED state files should NEVER be committed!"
    echo ""
    echo "To fix:"
    echo "  git reset HEAD $STAGED_ARCHIVED"
    echo "  rm -rf agent-states/ARCHIVED"
    echo ""
    exit 1
fi

exit 0
