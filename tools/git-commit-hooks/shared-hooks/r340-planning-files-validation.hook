#!/bin/bash
# R340 Planning Files Validation Hook
# Validates that planning_files section is updated when efforts exist
# Part of Software Factory 3.0 pre-commit validation

R340_HOOK_ENABLED=${R340_HOOK_ENABLED:-true}

if [ "$R340_HOOK_ENABLED" != "true" ]; then
    exit 0
fi

# Check if orchestrator-state-v3.json is being committed
if ! git diff --cached --name-only | grep -q "orchestrator-state-v3.json"; then
    exit 0  # Not updating state file, skip validation
fi

echo "🔍 R340: Validating planning_files tracking..."

# Get current state from staged file
CURRENT_STATE=$(git show :orchestrator-state-v3.json | jq -r '.state_machine.current_state // "UNKNOWN"')

# States that REQUIRE planning_files to be populated
MONITORING_STATES=(
    "MONITORING_SWE_PROGRESS"
    "MONITORING_EFFORT_REVIEWS"
    "MONITORING_EFFORT_FIXES"
    "MONITORING_BACKPORT_PROGRESS"
    "WAITING_FOR_EFFORT_PLANS"
    "ANALYZE_IMPLEMENTATION_PARALLELIZATION"
)

# Check if current state requires validation
REQUIRES_VALIDATION=false
for state in "${MONITORING_STATES[@]}"; do
    if [[ "$CURRENT_STATE" == "$state" ]]; then
        REQUIRES_VALIDATION=true
        break
    fi
done

if [ "$REQUIRES_VALIDATION" = "false" ]; then
    exit 0  # State doesn't require validation
fi

echo "  Current state: $CURRENT_STATE (requires R340 validation)"

# Extract current phase/wave from state file
CURRENT_PHASE=$(git show :orchestrator-state-v3.json | jq -r '.project_progression.current_phase // null')
CURRENT_WAVE=$(git show :orchestrator-state-v3.json | jq -r '.project_progression.current_wave // null')

if [[ "$CURRENT_PHASE" == "null" ]] || [[ "$CURRENT_WAVE" == "null" ]]; then
    echo "  ⚠️  Cannot determine current phase/wave - skipping R340 validation"
    exit 0
fi

echo "  Validating Phase $CURRENT_PHASE Wave $CURRENT_WAVE"

# Check if efforts directory exists for this phase/wave
EFFORTS_DIR="efforts/phase${CURRENT_PHASE}/wave${CURRENT_WAVE}"
if [ ! -d "$EFFORTS_DIR" ]; then
    echo "  ℹ️  No efforts directory yet - skipping validation"
    exit 0
fi

# Count actual effort directories
ACTUAL_EFFORT_COUNT=$(find "$EFFORTS_DIR" -maxdepth 1 -type d -name "effort-*" 2>/dev/null | wc -l)

if [ "$ACTUAL_EFFORT_COUNT" -eq 0 ]; then
    echo "  ℹ️  No efforts created yet - skipping validation"
    exit 0
fi

echo "  Found $ACTUAL_EFFORT_COUNT effort directories"

# Check state file planning_files tracking
TRACKED_EFFORTS=$(git show :orchestrator-state-v3.json | jq -r ".planning_files.phases.phase${CURRENT_PHASE}.waves.wave${CURRENT_WAVE}.efforts // {} | keys | length")

if [[ "$TRACKED_EFFORTS" == "0" ]] || [[ -z "$TRACKED_EFFORTS" ]]; then
    echo ""
    echo "❌ R340 VIOLATION DETECTED!"
    echo ""
    echo "Filesystem shows $ACTUAL_EFFORT_COUNT effort directories in:"
    echo "  $EFFORTS_DIR"
    echo ""
    echo "But orchestrator-state-v3.json shows:"
    echo "  planning_files.phases.phase${CURRENT_PHASE}.waves.wave${CURRENT_WAVE}.efforts: {} (EMPTY)"
    echo ""
    echo "R340 requires ALL efforts to be tracked with metadata in state file."
    echo ""
    echo "To fix this violation:"
    echo "1. Run: bash tools/discover-effort-metadata.sh phase${CURRENT_PHASE} wave${CURRENT_WAVE}"
    echo "2. Review and apply suggested updates"
    echo "3. Re-attempt commit"
    echo ""
    echo "Or disable this check temporarily (NOT RECOMMENDED):"
    echo "  R340_HOOK_ENABLED=false git commit ..."
    echo ""
    echo "PENALTY: -20% per untracked effort, -50% for filesystem scanning"
    echo ""
    exit 1
fi

echo "  ✅ Found $TRACKED_EFFORTS tracked efforts in state file"

# Additional validation: Check if tracked count matches filesystem
if [ "$TRACKED_EFFORTS" -lt "$ACTUAL_EFFORT_COUNT" ]; then
    MISSING=$((ACTUAL_EFFORT_COUNT - TRACKED_EFFORTS))
    echo ""
    echo "⚠️  WARNING: Possible R340 violation"
    echo "  Filesystem: $ACTUAL_EFFORT_COUNT efforts"
    echo "  State file: $TRACKED_EFFORTS efforts tracked"
    echo "  Missing: $MISSING efforts not tracked"
    echo ""
    echo "Run metadata discovery tool to identify missing efforts:"
    echo "  bash tools/discover-effort-metadata.sh phase${CURRENT_PHASE} wave${CURRENT_WAVE}"
    echo ""
    echo "Proceeding with commit (partial tracking detected)..."
fi

# Check for orphaned metadata files (completion markers not in state file)
if [ -d "$EFFORTS_DIR" ]; then
    COMPLETION_MARKERS=$(find "$EFFORTS_DIR" -name "IMPLEMENTATION-COMPLETE*.md" 2>/dev/null | wc -l)

    if [ "$COMPLETION_MARKERS" -gt 0 ]; then
        echo "  ℹ️  Found $COMPLETION_MARKERS completion markers - checking tracking..."

        # For each completion marker, verify it's tracked
        while IFS= read -r marker; do
            EFFORT_NAME=$(echo "$marker" | sed -n 's|.*/efforts/phase[0-9]*/wave[0-9]*/\([^/]*\)/.*|\1|p')

            if [ -n "$EFFORT_NAME" ]; then
                IS_TRACKED=$(git show :orchestrator-state-v3.json | jq -r ".planning_files.phases.phase${CURRENT_PHASE}.waves.wave${CURRENT_WAVE}.efforts[\"${EFFORT_NAME}\"].status // null")

                if [[ "$IS_TRACKED" == "null" ]]; then
                    echo "  ⚠️  Untracked completed effort: $EFFORT_NAME"
                elif [[ "$IS_TRACKED" != "completed" ]] && [[ "$IS_TRACKED" != "reviewed" ]] && [[ "$IS_TRACKED" != "approved" ]]; then
                    echo "  ⚠️  Completion marker exists but status=$IS_TRACKED: $EFFORT_NAME"
                fi
            fi
        done < <(find "$EFFORTS_DIR" -name "IMPLEMENTATION-COMPLETE*.md" 2>/dev/null)
    fi
fi

echo "✅ R340 validation passed"
exit 0
