#!/bin/bash

# Pre-commit hook for Software Factory 2.0 - Branch Name Validation
# This hook validates that the current branch follows Software Factory naming conventions
# Prevents commits to incorrectly named branches

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Get the git root directory
GIT_ROOT="$(git rev-parse --show-toplevel)"
cd "$GIT_ROOT"

# Function to print colored messages
print_error() {
    echo -e "${RED}${BOLD}❌ ERROR:${NC} ${RED}$1${NC}" >&2
}

print_success() {
    echo -e "${GREEN}${BOLD}✅ SUCCESS:${NC} ${GREEN}$1${NC}"
}

print_info() {
    echo -e "${BLUE}${BOLD}ℹ️  INFO:${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}${BOLD}⚠️  WARNING:${NC} ${YELLOW}$1${NC}"
}

# Function to get project prefix from multiple sources
get_project_prefix() {
    # Method 1: Try to extract from current branch name (MOST RELIABLE for effort repos)
    # This handles the case where effort repos don't have target-repo-config.yaml
    local current_branch="$(git branch --show-current)"
    if [[ "$current_branch" =~ ^([^/]+)/phase[0-9]+/wave[0-9]+/ ]]; then
        # Branch has format: prefix/phaseN/waveM/effort-name
        echo "${BASH_REMATCH[1]}"
        return 0
    fi

    # Method 2: Check for target-repo-config.yaml (for planning repo or configured repos)
    local config_file="$GIT_ROOT/target-repo-config.yaml"
    if [ -f "$config_file" ]; then
        # Try to extract project prefix using multiple methods
        local prefix=""

        # Method 2a: Try yq if available
        if command -v yq &> /dev/null; then
            # Try both yq syntaxes (Go version and Python version)
            prefix=$(yq eval '.branch_naming.project_prefix' "$config_file" 2>/dev/null || cat "$config_file" | yq '.branch_naming.project_prefix' 2>/dev/null | tr -d '"' || echo "")
        # Method 2b: Try jq if available
        elif command -v jq &> /dev/null; then
            # First convert yaml to json using python if available
            if command -v python3 &> /dev/null; then
                prefix=$(python3 -c "
import yaml, json, sys
try:
    with open('$config_file', 'r') as f:
        data = yaml.safe_load(f)
        print(data.get('branch_naming', {}).get('project_prefix', ''))
except:
    print('')
" 2>/dev/null || echo "")
            fi
        # Method 2c: Use grep as fallback
        else
            prefix=$(grep "project_prefix:" "$config_file" | sed 's/.*project_prefix:[[:space:]]*"\?\([^"]*\)"\?.*/\1/' | head -1)
        fi

        # Clean up the prefix (remove null, quotes, etc.)
        if [ "$prefix" = "null" ] || [ "$prefix" = "~" ] || [ -z "$prefix" ]; then
            prefix=""
        fi

        if [ -n "$prefix" ]; then
            echo "$prefix"
            return 0
        fi
    fi

    # Method 3: No prefix found (allow branches without prefix)
    echo ""
    return 0
}

# Function to infer correct branch name from current directory
infer_correct_branch_name() {
    local current_dir="$PWD"
    local relative_dir="${current_dir#$GIT_ROOT/}"

    # Get project prefix
    local prefix=$(get_project_prefix)

    # Check if we're in efforts directory structure
    if [[ "$relative_dir" =~ ^efforts/phase([0-9]+)/wave([0-9]+)/(.+)$ ]]; then
        local phase="${BASH_REMATCH[1]}"
        local wave="${BASH_REMATCH[2]}"
        local effort_or_rest="${BASH_REMATCH[3]}"

        # Remove any trailing slashes and subdirectories
        effort_or_rest="${effort_or_rest%%/*}"

        # Check for special directories
        if [ "$effort_or_rest" = "wave-planning" ] || [ "$effort_or_rest" = "integration" ]; then
            effort_or_rest="integration"
        fi

        # Build the branch name
        if [ -n "$prefix" ]; then
            echo "${prefix}/phase${phase}/wave${wave}/${effort_or_rest}"
        else
            echo "phase${phase}/wave${wave}/${effort_or_rest}"
        fi
    # Check for phase-level integration
    elif [[ "$relative_dir" =~ ^efforts/phase([0-9]+)/integration$ ]]; then
        local phase="${BASH_REMATCH[1]}"
        if [ -n "$prefix" ]; then
            echo "${prefix}/phase${phase}/integration"
        else
            echo "phase${phase}/integration"
        fi
    # Check for project-level integration
    elif [[ "$relative_dir" =~ ^efforts/integration$ ]]; then
        if [ -n "$prefix" ]; then
            echo "${prefix}/integration"
        else
            echo "integration"
        fi
    else
        # If we can't infer, return empty
        echo ""
    fi
}

# Function to validate branch name pattern
validate_branch_name() {
    local branch="$1"
    local prefix=$(get_project_prefix)

    # Build valid patterns
    local valid_patterns=()

    # With project prefix
    if [ -n "$prefix" ]; then
        # Effort branches (including splits and fixes)
        valid_patterns+=("^${prefix}/phase[0-9]+/wave[0-9]+/[-a-z0-9.]+(--split-[0-9]{3})?(-fix)?$")
        # Wave integration branches
        valid_patterns+=("^${prefix}/phase[0-9]+/wave[0-9]+/integration$")
        # Phase integration branches
        valid_patterns+=("^${prefix}/phase[0-9]+/integration$")
        # Project integration branch
        valid_patterns+=("^${prefix}/integration$")
    else
        # Without project prefix
        # Effort branches (including splits and fixes)
        valid_patterns+=("^phase[0-9]+/wave[0-9]+/[-a-z0-9.]+(--split-[0-9]{3})?(-fix)?$")
        # Wave integration branches
        valid_patterns+=("^phase[0-9]+/wave[0-9]+/integration$")
        # Phase integration branches
        valid_patterns+=("^phase[0-9]+/integration$")
        # Project integration branch
        valid_patterns+=("^integration$")
    fi

    # Special allowed branches
    valid_patterns+=("^main$")
    valid_patterns+=("^master$")
    valid_patterns+=("^develop$")
    valid_patterns+=("^staging$")
    valid_patterns+=("^production$")
    valid_patterns+=("^hotfix/.*$")
    valid_patterns+=("^release/.*$")
    valid_patterns+=("^feature/.*$")  # Allow traditional feature branches
    valid_patterns+=("^bugfix/.*$")   # Allow traditional bugfix branches

    # Check against all valid patterns
    for pattern in "${valid_patterns[@]}"; do
        if [[ "$branch" =~ $pattern ]]; then
            return 0
        fi
    done

    return 1
}

# Main validation logic
main() {
    # Skip validation if SKIP_BRANCH_VALIDATION is set
    if [ "${SKIP_BRANCH_VALIDATION:-}" = "true" ]; then
        exit 0
    fi

    # Get current branch
    local current_branch="$(git branch --show-current)"

    # Skip if we're in a detached HEAD state
    if [ -z "$current_branch" ]; then
        exit 0
    fi

    # Validate the branch name
    if ! validate_branch_name "$current_branch"; then
        echo ""
        print_error "BRANCH NAME VALIDATION FAILED!"
        echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""

        # Try to infer the correct branch name
        local correct_branch=$(infer_correct_branch_name)

        if [ -n "$correct_branch" ]; then
            echo -e "${RED}${BOLD}WRONG! YOU ARE NOT ALLOWED TO USE BRANCH NAMES THAT DON'T FOLLOW THE NAMING CONVENTIONS.${NC}"
            echo -e "${RED}YOUR BRANCH NAME SHOULD BE ${BOLD}${correct_branch}${NC}${RED}.${NC}"
            echo -e "${RED}PLEASE CREATE YOUR COMMITS ON THE CORRECT BRANCH AND THEN DELETE THE ERRONEOUS BRANCH NAME ${BOLD}${current_branch}${NC}"
            echo ""
            print_info "To fix this issue:"
            echo -e "  1. ${BOLD}git stash${NC}              # Save your changes"
            echo -e "  2. ${BOLD}git checkout -b \"${correct_branch}\"${NC}"
            echo -e "  3. ${BOLD}git stash pop${NC}           # Restore your changes"
            echo -e "  4. ${BOLD}git add .${NC}               # Stage your changes"
            echo -e "  5. ${BOLD}git commit${NC}              # Commit again"
            echo -e "  6. ${BOLD}git branch -D \"${current_branch}\"${NC}  # Delete the old branch"
        else
            echo -e "${RED}${BOLD}WRONG! YOU ARE NOT ALLOWED TO USE BRANCH NAMES THAT DON'T FOLLOW THE NAMING CONVENTIONS.${NC}"
            echo -e "${RED}Current branch: ${BOLD}${current_branch}${NC}"
            echo ""
            print_error "This branch name does not follow Software Factory naming conventions."
            print_info "Valid branch name patterns for effort repositories:"
            local prefix=$(get_project_prefix)
            if [ -n "$prefix" ]; then
                echo "  • ${prefix}/phase{X}/wave{Y}/{effort-name}"
                echo "  • ${prefix}/phase{X}/wave{Y}/{effort-name}--split-{NNN}"
                echo "  • ${prefix}/phase{X}/wave{Y}/{effort-name}-fix"
                echo "  • ${prefix}/phase{X}/wave{Y}/integration"
                echo "  • ${prefix}/phase{X}/integration"
                echo "  • ${prefix}/integration"
            else
                echo "  • phase{X}/wave{Y}/{effort-name}"
                echo "  • phase{X}/wave{Y}/{effort-name}--split-{NNN}"
                echo "  • phase{X}/wave{Y}/{effort-name}-fix"
                echo "  • phase{X}/wave{Y}/integration"
                echo "  • phase{X}/integration"
                echo "  • integration"
            fi
        fi

        echo ""
        echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""

        # Exit with error
        exit 1
    fi

    # Branch name is valid
    exit 0
}

# Run main function
main "$@"